# ============================================================
# ClinicBooking — Environment Variables Template
# SAO CHEP FILE NAY THANH .env VA DIEN GIA TRI THUC TE
# TUYET DOI KHONG COMMIT FILE .env VAO GIT
# ============================================================

# ── Database ────────────────────────────────────────────────
# Mat khau SQL Server SA — toi thieu 8 ky tu, co chu hoa + so + ky tu dac biet
DB_SA_PASSWORD=YourStrong@Passw0rd

# ── JWT ─────────────────────────────────────────────────────
# Key bi mat JWT — toi thieu 32 ky tu, ngau nhien
JWT_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ISSUER=ClinicBooking
JWT_AUDIENCE=ClinicBookingClients
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# ── Admin seed ──────────────────────────────────────────────
ADMIN_MAT_KHAU_MAC_DINH=Admin@123456

# ── API ─────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
API_PORT=8080

# ── Email (Tuan 3 Module 4 — de trong neu chua dung) ────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_TEN_NGUOI_GUI=ClinicBooking
EMAIL_DIA_CHI_GUI=noreply@yourclinic.com
EMAIL_TEN_DANG_NHAP=your@gmail.com
EMAIL_MAT_KHAU=your-app-password
