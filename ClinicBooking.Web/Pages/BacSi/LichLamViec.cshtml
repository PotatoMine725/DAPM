@page
@model ClinicBooking.Web.Pages.BacSi.LichLamViecModel
@{
    ViewData["Title"] = "Lịch làm việc";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Lịch làm việc</h1>
        <div class="page-subtitle">Xem lịch theo tuần/tháng của bác sĩ đang đăng nhập.</div>
    </div>
</div>

<div class="card section-stack" style="padding: var(--space-4); margin-bottom: var(--space-4);">
    <form method="get" class="filter-bar">
        <div class="form-group" style="margin:0; min-width:220px;">
            <label class="form-label" for="tuNgay">Từ ngày</label>
            <input class="form-input" type="date" id="tuNgay" name="tuNgay" value="@Model.TuNgay.ToString("yyyy-MM-dd")" />
        </div>
        <div class="form-group" style="margin:0; min-width:160px;">
            <label class="form-label" for="soTuan">Số tuần</label>
            <input class="form-input" type="number" id="soTuan" name="soTuan" min="1" max="12" value="@Model.SoTuan" />
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M8 3v4M16 3v4M4 9h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="4" y="5" width="16" height="16" rx="2" stroke="currentColor" stroke-width="2"/></svg> Xem lịch</button>
        </div>
    </form>
</div>

<div class="stats-grid stats-grid--responsive" style="margin-bottom: var(--space-4);">
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-primary-light); color:var(--color-primary);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M8 3v4M16 3v4M4 9h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="4" y="5" width="16" height="16" rx="2" stroke="currentColor" stroke-width="2"/></svg></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count</div>
            <div class="stat-label">Tổng ca trong kỳ</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-active-bg); color:var(--color-active-text);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count(x => x.TrangThaiDuyet == "DaDuyet")</div>
            <div class="stat-label">Đã duyệt</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-warning-bg); color:var(--color-warning-text);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M6 4h12M6 20h12M8 4c0 3 2 5 4 8-2 3-4 5-4 8M16 4c0 3-2 5-4 8 2 3 4 5 4 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count(x => x.TrangThaiDuyet == "ChoDuyet")</div>
            <div class="stat-label">Chờ duyệt</div>
        </div>
    </div>
</div>

<div class="card section-stack">
    <div class="card-header">
        <span class="card-title"><i class="ph ph-calendar-dots"></i> Danh sách ca</span>
    </div>

    @if (!Model.DanhSachCa.Any())
    {
        <div class="empty-state" style="padding: var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-calendar-x"></i></div>
            <p>Chưa có ca làm việc trong khoảng thời gian đã chọn.</p>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Phòng</th>
                <th>Chuyên khoa</th>
                <th>Trạng thái</th>
                <th>Slot</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var ca in Model.DanhSachCa)
            {
                <tr>
                    <td><strong>@ca.NgayLamViec.ToString("dd/MM/yyyy")</strong></td>
                    <td>@ca.GioBatDau.ToString("HH:mm") - @ca.GioKetThuc.ToString("HH:mm")</td>
                    <td>@ca.MaPhong</td>
                    <td>@ca.TenChuyenKhoa</td>
                    <td>
                        <span class="badge @(ca.TrangThaiDuyet == "DaDuyet" ? "badge-success" : ca.TrangThaiDuyet == "ChoDuyet" ? "badge-warning" : "badge-neutral")">@ca.TrangThaiDuyet</span>
                    </td>
                    <td>@(ca.ConTrong ? "Còn" : "Hết")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
