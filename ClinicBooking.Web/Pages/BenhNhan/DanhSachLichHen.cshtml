@page
@model ClinicBooking.Web.Pages.BenhNhan.DanhSachLichHenModel
@using ClinicBooking.Domain.Enums
@{
    ViewData["Title"] = "Lịch hẹn";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Lịch hẹn</h1>
        <div class="page-subtitle">Theo dõi và quản lý các lịch đã tạo.</div>
    </div>
    <div class="action-bar">
        <a href="/BenhNhan/DatLich" class="btn btn-primary">
            <i class="ph ph-calendar-plus"></i> Đặt lịch mới
        </a>
    </div>
</div>

<div class="card section-stack" style="padding: var(--space-4); margin-bottom: var(--space-4);">
    <form method="get" class="filter-bar">
        <div class="form-group" style="margin:0; min-width:220px;">
            <label class="form-label" for="trangThai">Trạng thái</label>
            <select class="form-select" name="trangThai" id="trangThai">
                <option value="">— Tất cả —</option>
                @foreach (TrangThaiLichHen tt in Enum.GetValues(typeof(TrangThaiLichHen)))
                {
                    <option value="@((int)tt)" selected="@(Model.TrangThaiFilter == tt ? "selected" : null)">
                        @BadgeHelper.TrangThaiText(tt)
                    </option>
                }
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">
                <i class="ph ph-funnel"></i> Lọc
            </button>
            @if (Model.TrangThaiFilter.HasValue)
            {
                <a href="/BenhNhan/DanhSachLichHen" class="btn btn-ghost">Xoá lọc</a>
            }
        </div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">
            Kết quả: <strong>@Model.DanhSach.TongSo</strong> lịch hẹn
        </span>
    </div>

    @if (!Model.DanhSach.KetQua.Any())
    {
        <div class="empty-state" style="padding: var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-calendar-x"></i></div>
            <p>Bạn chưa có lịch hẹn nào.</p>
        </div>
    }
    else
    {
        <div class="appointment-list">
            @foreach (var lh in Model.DanhSach.KetQua)
            {
                <article class="appointment-card">
                    <div class="appointment-card__top">
                        <div>
                            <div class="appointment-code">@lh.MaLichHen</div>
                            <div class="appointment-meta">
                                @lh.NgayLamViec.ToString("dd/MM/yyyy") · @lh.GioBatDau.ToString("HH:mm")
                            </div>
                        </div>
                        @Html.Raw(BadgeHelper.TrangThaiLichHen(lh.TrangThai))
                    </div>

                    <div class="appointment-card__body">
                        <div class="summary-item">
                            <span class="summary-label">Dịch vụ</span>
                            <span>@lh.TenDichVu</span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">Ngày đặt</span>
                            <span>@lh.NgayTao.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>

                    <div class="appointment-card__actions">
                        <a class="btn btn-sm btn-secondary" href="/BenhNhan/LichHen/@lh.IdLichHen">
                            <i class="ph ph-eye"></i> Chi tiết
                        </a>
                        @if (lh.TrangThai == TrangThaiLichHen.ChoXacNhan ||
                             lh.TrangThai == TrangThaiLichHen.DaXacNhan)
                        {
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    onclick="openModal('modal-huy-@lh.IdLichHen')">
                                <i class="ph ph-x-circle"></i> Huỷ
                            </button>

                            <div id="modal-huy-@lh.IdLichHen" class="modal-overlay" hidden>
                                <div class="modal-box" style="max-width:420px;">
                                    <div class="modal-header">
                                        <span class="modal-title">Huỷ lịch hẹn</span>
                                        <button type="button" class="btn btn-ghost btn-icon"
                                                onclick="closeModal('modal-huy-@lh.IdLichHen')">
                                            <i class="ph ph-x"></i>
                                        </button>
                                    </div>
                                    <div class="modal-body">
                                        <p class="form-hint" style="margin-bottom: var(--space-4);">
                                            Bạn có chắc muốn huỷ lịch hẹn <strong>@lh.MaLichHen</strong>?
                                            Hành động này không thể hoàn tác.
                                        </p>
                                        <form method="post" asp-page-handler="Huy">
                                            <input type="hidden" name="idLichHen" value="@lh.IdLichHen" />
                                            <div class="form-group">
                                                <label class="form-label">Lý do huỷ (tuỳ chọn)</label>
                                                <input type="text" class="form-input" name="lyDo"
                                                       placeholder="Nhập lý do..." maxlength="200" />
                                            </div>
                                            <div class="modal-footer" style="padding-left:0; padding-right:0; border-top:none; background:transparent;">
                                                <button type="button" class="btn btn-ghost"
                                                        onclick="closeModal('modal-huy-@lh.IdLichHen')">Đóng</button>
                                                <button type="submit" class="btn btn-danger">Xác nhận huỷ</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>

        @if (Model.TongSoTrang > 1)
        {
            <div class="pagination" style="padding: var(--space-3) var(--space-5);">
                @if (Model.DanhSach.SoTrang > 1)
                {
                    <a href="?soTrang=@(Model.DanhSach.SoTrang - 1)@(Model.TrangThaiFilter.HasValue ? "&trangThai=" + (int)Model.TrangThaiFilter : "")"
                       class="pagination-btn">
                        <i class="ph ph-caret-left"></i>
                    </a>
                }
                @for (int i = 1; i <= Model.TongSoTrang; i++)
                {
                    <a href="?soTrang=@i@(Model.TrangThaiFilter.HasValue ? "&trangThai=" + (int)Model.TrangThaiFilter : "")"
                       class="pagination-btn @(i == Model.DanhSach.SoTrang ? "active" : "")">@i</a>
                }
                @if (Model.DanhSach.SoTrang < Model.TongSoTrang)
                {
                    <a href="?soTrang=@(Model.DanhSach.SoTrang + 1)@(Model.TrangThaiFilter.HasValue ? "&trangThai=" + (int)Model.TrangThaiFilter : "")"
                       class="pagination-btn">
                        <i class="ph ph-caret-right"></i>
                    </a>
                }
            </div>
        }
    }
</div>
