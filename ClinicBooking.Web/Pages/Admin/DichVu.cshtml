                </td>
                <td>
                    <label class="toggle">
                        <input type="checkbox">
                        <span class="toggle-slider"></span>
                    </label>
                </td>
                <td>
                    <div class="action-btns">
                        <button class="btn btn-ghost btn-sm" onclick="editService(4)">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteService(4)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="color:var(--text-disabled)">#5</td>
                <td><strong>Laser điều trị da</strong></td>
                <td><span class="badge" style="background:#fae8ff;color:#9333ea">Da liễu</span></td>
