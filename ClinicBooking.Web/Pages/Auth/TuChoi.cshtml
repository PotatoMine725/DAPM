@page
@{
    Layout = "~/Pages/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Không có quyền truy cập";
}
<div class="login-shell">
    <div class="login-card" style="text-align:center;">
        <div style="font-size:48px; margin-bottom:16px; color:#9aa0a6;">
            <i class="ph ph-lock"></i>
        </div>
        <h2 style="margin-bottom:8px;">Không có quyền truy cập</h2>
        <p style="color:#5f6368; margin-bottom:24px;">Tài khoản của bạn không có quyền xem trang này.</p>
        <a href="/Auth/DangNhap" class="btn btn-primary">Về trang đăng nhập</a>
    </div>
</div>
