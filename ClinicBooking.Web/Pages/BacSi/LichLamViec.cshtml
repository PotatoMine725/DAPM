@page
@model ClinicBooking.Web.Pages.BacSi.LichLamViecModel
@{
    ViewData["Title"] = "Lịch làm việc";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Lịch làm việc</h1>
        <div class="page-subtitle">Xem lịch theo tuần/tháng của bác sĩ đang đăng nhập.</div>
    </div>
</div>

<div class="card section-stack" style="padding: var(--space-4); margin-bottom: var(--space-4);">
    <form method="get" class="filter-bar">
        <div class="form-group" style="margin:0; min-width:220px;">
            <label class="form-label" for="tuNgay">Từ ngày</label>
            <input class="form-input" type="date" id="tuNgay" name="tuNgay" value="@Model.TuNgay.ToString("yyyy-MM-dd")" />
        </div>
        <div class="form-group" style="margin:0; min-width:160px;">
            <label class="form-label" for="soTuan">Số tuần</label>
            <input class="form-input" type="number" id="soTuan" name="soTuan" min="1" max="12" value="@Model.SoTuan" />
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn btn-primary"><i class="ph ph-calendar"></i> Xem lịch</button>
        </div>
    </form>
</div>

<div class="stats-grid stats-grid--responsive" style="margin-bottom: var(--space-4);">
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-primary-light); color:var(--color-primary);"><i class="ph ph-calendar"></i></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count</div>
            <div class="stat-label">Tổng ca trong kỳ</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-active-bg); color:var(--color-active-text);"><i class="ph ph-check-circle"></i></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count(x => x.TrangThaiDuyet == "DaDuyet")</div>
            <div class="stat-label">Đã duyệt</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:var(--color-warning-bg); color:var(--color-warning-text);"><i class="ph ph-hourglass-medium"></i></div>
        <div>
            <div class="stat-value">@Model.DanhSachCa.Count(x => x.TrangThaiDuyet == "ChoDuyet")</div>
            <div class="stat-label">Chờ duyệt</div>
        </div>
    </div>
</div>

<div class="card section-stack">
    <div class="card-header">
        <span class="card-title"><i class="ph ph-calendar-dots"></i> Danh sách ca</span>
    </div>

    @if (!Model.DanhSachCa.Any())
    {
        <div class="empty-state" style="padding: var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-calendar-x"></i></div>
            <p>Chưa có ca làm việc trong khoảng thời gian đã chọn.</p>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Phòng</th>
                <th>Chuyên khoa</th>
                <th>Trạng thái</th>
                <th>Slot</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var ca in Model.DanhSachCa)
            {
                <tr>
                    <td><strong>@ca.NgayLamViec.ToString("dd/MM/yyyy")</strong></td>
                    <td>@ca.GioBatDau.ToString("HH:mm") - @ca.GioKetThuc.ToString("HH:mm")</td>
                    <td>@ca.MaPhong</td>
                    <td>@ca.TenChuyenKhoa</td>
                    <td>
                        <span class="badge @(ca.TrangThaiDuyet == "DaDuyet" ? "badge-success" : ca.TrangThaiDuyet == "ChoDuyet" ? "badge-warning" : "badge-neutral")">@ca.TrangThaiDuyet</span>
                    </td>
                    <td>@(ca.ConTrong ? "Còn" : "Hết")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
