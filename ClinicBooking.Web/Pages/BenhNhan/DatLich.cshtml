@page
@model ClinicBooking.Web.Pages.BenhNhan.DatLichModel
@{
    ViewData["Title"] = "Đặt lịch khám";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Đặt lịch online</h1>
        <div class="page-subtitle">Chọn ngày đến khám, nhập giờ mong muốn và xác thực OTP trước khi hoàn tất.</div>
    </div>
    <div class="action-bar">
        <a href="/BenhNhan/DanhSachLichHen" class="btn btn-secondary">Quay lại lịch hẹn</a>
    </div>
</div>

@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (Model.CanhBaoThieuBacSi.Any(x => x.HoanToanTrong))
{
    <div class="alert alert-danger" style="margin-bottom: var(--space-4);">Không có bác sĩ chuyên khoa này trong ngày đã chọn. Vui lòng chọn ngày khác hoặc chuyên khoa khác.</div>
}
else if (Model.CanhBaoThieuBacSi.Any())
{
    <div class="alert alert-warning" style="margin-bottom: var(--space-4);">Có ngày cần duyệt ca để đảm bảo đủ bác sĩ. Một số khung giờ vẫn đang chờ duyệt.</div>
}

<div class="card" style="padding: var(--space-4); margin-bottom: var(--space-4); border-left: 3px solid var(--color-primary-mid);">
    <div class="card-title" style="margin-bottom: var(--space-2);">Đặt lịch khám</div>
    <div class="form-hint">Chọn thông tin khám và hoàn tất đặt lịch</div>
</div>

<form method="post" class="panel-grid-2">
    <div class="section-stack">
        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-calendar"></i> Thông tin đặt lịch</span>
            </div>
            <div style="padding: var(--space-4);" class="section-stack">
                <div class="form-group">
                    <label class="form-label">Ngày đến khám</label>
                    <input type="date" class="form-input" asp-for="NgayChon" min="@DateOnly.FromDateTime(DateTime.Now.AddDays(1)).ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">Giờ mong muốn</label>
                    <input type="time" class="form-input" asp-for="GioMongMuon" />
                    <div class="form-hint">Bạn chọn giờ mong muốn, hệ thống sẽ tự tìm ca khám phù hợp và sắp xếp sau khi đặt lịch.</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Dịch vụ khám</label>
                    <select class="form-select" asp-for="IdDichVu" style="width:100%;" required>
                        <option value="0">— Chọn dịch vụ —</option>
                        @foreach (var dv in Model.DanhSachDichVu)
                        {
                            <option value="@dv.IdDichVu">@dv.TenDichVu</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Lý do khám / triệu chứng</label>
                    <textarea class="form-input" asp-for="TrieuChung" rows="4" placeholder="Mệt mỏi, cơn đau, tái khám..."></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Ghi chú (nếu có)</label>
                    <textarea class="form-input" asp-for="GhiChu" rows="3" placeholder="Muốn gặp bác sĩ đã khám lần trước..."></textarea>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-shield-check"></i> Xác thực</span>
                <span class="badge badge-primary">Bước 3</span>
            </div>
            <div style="padding: var(--space-4);" class="section-stack">
                @if (Model.BatBuocOtp)
                {
                    <div class="form-group">
                        <label class="form-label">Mã OTP</label>
                        <input type="text" class="form-input" asp-for="Otp" maxlength="6" inputmode="numeric" placeholder="Nhập 6 số" />
                    </div>
                    <div class="filter-actions">
                        <button type="submit" formaction="?handler=GuiOtp" class="btn btn-secondary">Gửi mã OTP</button>
                        <button type="submit" class="btn btn-primary">Hoàn tất đặt lịch</button>
                    </div>
                }
                else
                {
                    <div class="form-hint">OTP đang được tắt theo cấu hình Development. Bạn có thể đặt lịch trực tiếp.</div>
                    <div class="filter-actions"><button type="submit" class="btn btn-primary">Hoàn tất đặt lịch</button></div>
                }
            </div>
        </div>
    </div>

    <div class="section-stack">
        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-list"></i> Ca khám khả dụng</span>
            </div>
            <div style="padding: var(--space-4);" class="section-stack">
                @if (!Model.DanhSachCa.Any())
                {
                    <div class="empty-state" style="padding: var(--space-6);">
                        <div class="empty-state-icon"><i class="ph ph-calendar-x"></i></div>
                        <p>Không tìm thấy ca phù hợp trong ngày đã chọn.</p>
                    </div>
                }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Ca</th><th>Bác sĩ</th><th>Phòng</th><th>Giờ</th></tr></thead>
                        <tbody>
                        @foreach (var ca in Model.DanhSachCa)
                        {
                            <tr>
                                <td>@ca.IdCaLamViec</td>
                                <td>@ca.TenChuyenKhoa</td>
                                <td>@ca.IdPhong</td>
                                <td>@ca.GioBatDau.ToString("HH:mm") - @ca.GioKetThuc.ToString("HH:mm")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</form>
