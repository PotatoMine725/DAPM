@{
    var pageName = ViewData["PageName"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["PageTitle"]?.ToString() ?? string.Empty;
}

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
            <div class="admin-brand">MedAdmin</div>
            <div class="admin-brand-sub">Quản trị hệ thống</div>
        </div>
        <nav class="admin-nav">
            <a class="admin-nav-item @(pageName == "dashboard" ? "active" : "")" href="/Admin/Dashboard">Tổng quan</a>
            <a class="admin-nav-item @(pageName == "bacsi" ? "active" : "")" href="/Admin/BacSi">Bác sĩ</a>
            <a class="admin-nav-item @(pageName == "calamviec" ? "active" : "")" href="/Admin/CaLamViec">Ca làm việc</a>
            <a class="admin-nav-item @(pageName == "nghiphep" ? "active" : "")" href="/Admin/NghiPhep">Nghỉ phép</a>
            <a class="admin-nav-item @(pageName == "danhmuc" ? "active" : "")" href="/Admin/QuanLyDanhMuc">Danh mục</a>
        </nav>
    </aside>
    <main class="admin-content">
        <div class="admin-content-header">
            <h1>@pageTitle</h1>
        </div>
        @RenderBody()
    </main>
</div>
