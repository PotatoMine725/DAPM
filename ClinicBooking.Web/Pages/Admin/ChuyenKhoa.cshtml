@page
@model ClinicBooking.Web.Pages.Admin.ChuyenKhoaModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý chuyên khoa - MedAdmin";
    ViewData["PageName"] = "chuyenkhoa";
    ViewData["PageTitle"] = "Quản lý chuyên khoa";
}

<!-- Search and Actions -->
<div class="card">
    <div class="card-header-flex">
        <div class="card-title">Danh sách chuyên khoa</div>
        <button class="btn btn-primary" onclick="showModal('modal-create-specialty')">
            <i class="fa-solid fa-plus"></i> Thêm chuyên khoa mới
        </button>
    </div>
    
    <div class="search-bar" style="padding: 0 24px 20px;">
        <div class="search-input">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="form-control" id="search-specialties" placeholder="Tìm theo tên chuyên khoa...">
        </div>
        <select class="form-select" style="width: 200px;" id="filter-status">
            <option value="">Tất cả trạng thái</option>
            <option value="true">Hoạt động</option>
            <option value="false">Ngừng hoạt động</option>
        </select>
    </div>
</div>

<!-- Specialties Grid -->
<div class="specialties-grid" id="specialties-grid">
    <div class="specialty-card">
        <div class="specialty-header">
            <div class="specialty-icon" style="background: var(--primary-light); color: var(--primary);">
                <i class="fa-solid fa-stethoscope"></i>
            </div>
            <div class="specialty-info">
                <div class="specialty-name">Nội tổng quát</div>
                <div class="specialty-code">NT001</div>
            </div>
            <span class="badge badge-success">Hoạt động</span>
        </div>
        <div class="specialty-details">
            <div class="detail-row">
                <label>Số bác sĩ:</label>
                <span>5 bác sĩ</span>
            </div>
            <div class="detail-row">
                <label>Số phòng:</label>
                <span>3 phòng</span>
            </div>
            <div class="detail-row">
                <label>Giá khám:</label>
                <span>200.000 VNĐ</span>
            </div>
        </div>
        <div class="specialty-actions">
            <button class="icon-btn" title="Chỉnh sửa">
                <i class="fa-solid fa-edit"></i>
            </button>
            <button class="icon-btn" title="Xem chi tiết">
                <i class="fa-solid fa-eye"></i>
            </button>
            <button class="icon-btn" title="Ngừng hoạt động" style="color: var(--warning)">
                <i class="fa-solid fa-pause"></i>
            </button>
        </div>
    </div>

    <div class="specialty-card">
        <div class="specialty-header">
            <div class="specialty-icon" style="background: var(--success-bg); color: var(--success);">
                <i class="fa-solid fa-heart"></i>
            </div>
            <div class="specialty-info">
                <div class="specialty-name">Tim mạch</div>
                <div class="specialty-code">TM001</div>
            </div>
            <span class="badge badge-success">Hoạt động</span>
        </div>
        <div class="specialty-details">
            <div class="detail-row">
                <label>Số bác sĩ:</label>
                <span>3 bác sĩ</span>
            </div>
            <div class="detail-row">
                <label>Số phòng:</label>
                <span>2 phòng</span>
            </div>
            <div class="detail-row">
                <label>Giá khám:</label>
                <span>350.000 VNĐ</span>
            </div>
        </div>
        <div class="specialty-actions">
            <button class="icon-btn" title="Chỉnh sửa">
                <i class="fa-solid fa-edit"></i>
            </button>
            <button class="icon-btn" title="Xem chi tiết">
                <i class="fa-solid fa-eye"></i>
            </button>
            <button class="icon-btn" title="Ngừng hoạt động" style="color: var(--warning)">
                <i class="fa-solid fa-pause"></i>
            </button>
        </div>
    </div>

    <div class="specialty-card">
        <div class="specialty-header">
            <div class="specialty-icon" style="background: var(--warning-bg); color: var(--warning);">
                <i class="fa-solid fa-baby"></i>
            </div>
            <div class="specialty-info">
                <div class="specialty-name">Nhi</div>
                <div class="specialty-code">NH001</div>
            </div>
            <span class="badge badge-success">Hoạt động</span>
        </div>
        <div class="specialty-details">
            <div class="detail-row">
                <label>Số bác sĩ:</label>
                <span>2 bác sĩ</span>
            </div>
            <div class="detail-row">
                <label>Số phòng:</label>
                <span>1 phòng</span>
            </div>
            <div class="detail-row">
                <label>Giá khám:</label>
                <span>250.000 VNĐ</span>
            </div>
        </div>
        <div class="specialty-actions">
            <button class="icon-btn" title="Chỉnh sửa">
                <i class="fa-solid fa-edit"></i>
            </button>
            <button class="icon-btn" title="Xem chi tiết">
                <i class="fa-solid fa-eye"></i>
            </button>
            <button class="icon-btn" title="Ngừng hoạt động" style="color: var(--warning)">
                <i class="fa-solid fa-pause"></i>
            </button>
        </div>
    </div>

    <div class="specialty-card">
        <div class="specialty-header">
            <div class="specialty-icon" style="background: var(--danger-bg); color: var(--danger);">
                <i class="fa-solid fa-venus"></i>
            </div>
            <div class="specialty-info">
                <div class="specialty-name">Sản</div>
                <div class="specialty-code">SP001</div>
            </div>
            <span class="badge badge-success">Hoạt động</span>
        </div>
        <div class="specialty-details">
            <div class="detail-row">
                <label>Số bác sĩ:</label>
                <span>4 bác sĩ</span>
            </div>
            <div class="detail-row">
                <label>Số phòng:</label>
                <span>2 phòng</span>
            </div>
            <div class="detail-row">
                <label>Giá khám:</label>
                <span>300.000 VNĐ</span>
            </div>
        </div>
        <div class="specialty-actions">
            <button class="icon-btn" title="Chỉnh sửa">
                <i class="fa-solid fa-edit"></i>
            </button>
            <button class="icon-btn" title="Xem chi tiết">
                <i class="fa-solid fa-eye"></i>
            </button>
            <button class="icon-btn" title="Ngừng hoạt động" style="color: var(--warning)">
                <i class="fa-solid fa-pause"></i>
            </button>
        </div>
    </div>
</div>

<!-- Create Specialty Modal -->
<div class="modal-overlay" id="modal-create-specialty">
    <div class="modal-content">
        <div class="modal-header">
            <div class="modal-title">Thêm chuyên khoa mới</div>
            <button class="modal-close" onclick="hideModal('modal-create-specialty')">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="modal-body">
            <form id="create-specialty-form">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Tên chuyên khoa *</label>
                        <input type="text" class="form-control" name="tenChuyenKhoa" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mã chuyên khoa *</label>
                        <input type="text" class="form-control" name="maChuyenKhoa" required>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Giá khám (VNĐ) *</label>
                        <input type="number" class="form-control" name="giaKham" min="0" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" name="moTa" rows="3"></textarea>
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" name="trangThai" checked> 
                        Chuyên khoa hoạt động
                    </label>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="hideModal('modal-create-specialty')">
                Hủy
            </button>
            <button type="button" class="btn btn-primary" onclick="createSpecialty()">
                Thêm chuyên khoa
            </button>
        </div>
    </div>
</div>

<style>
.search-bar {
    display: flex;
    gap: 12px;
    align-items: center;
}

.search-input {
    flex: 1;
    position: relative;
}

.search-input i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-disabled);
    font-size: 13px;
}

.search-input input {
    padding-left: 40px;
}

.specialties-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
}

.specialty-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    transition: .2s;
}

.specialty-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.specialty-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
}

.specialty-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
}

.specialty-info {
    flex: 1;
}

.specialty-info .specialty-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
}

.specialty-info .specialty-code {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 2px;
}

.specialty-details {
    margin-bottom: 16px;
}

.detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--subtle);
}

.detail-row:last-child {
    border-bottom: none;
}

.detail-row label {
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 500;
}

.detail-row span {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 600;
}

.specialty-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.icon-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: none;
    background: var(--subtle);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: .2s;
    font-size: 14px;
}

.icon-btn:hover {
    background: var(--primary-light);
    color: var(--primary);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}
</style>

<script>
function createSpecialty() {
    const form = document.getElementById('create-specialty-form');
    const formData = new FormData(form);
    
    // Validate form
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    // Create specialty logic here
    showToast('Chuyên khoa đã được thêm thành công!', 'success');
    hideModal('modal-create-specialty');
    form.reset();
}

// Search functionality
document.getElementById('search-specialties')?.addEventListener('input', function() {
    const query = this.value.toLowerCase();
    const cards = document.querySelectorAll('.specialty-card');
    
    cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? '' : 'none';
    });
});

// Filter functionality
document.getElementById('filter-status')?.addEventListener('change', function() {
    const status = this.value;
    const cards = document.querySelectorAll('.specialty-card');
    
    cards.forEach(card => {
        let show = true;
        
        if (status && !card.textContent.includes(status === 'true' ? 'Hoạt động' : 'Ngừng hoạt động')) {
            show = false;
        }
        
        card.style.display = show ? '' : 'none';
    });
});
</script>
