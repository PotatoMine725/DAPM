<!-- Modal: Thêm dịch vụ -->
<div class="modal-overlay" id="modal-add-dv">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fa-solid fa-syringe" style="color:var(--primary);margin-right:8px"></i>Thêm dịch vụ mới</div>
      <div class="modal-close" onclick="closeModal('modal-add-dv')"><i class="fa-solid fa-times"></i></div>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-group"><label>Tên dịch vụ <span class="req">*</span></label><input type="text" class="form-control" placeholder="VD: Khám tổng quát, Siêu âm ổ bụng..."></div>
        <div class="form-group">
          <label>Chuyên khoa <span class="req">*</span></label>
          <select class="form-control"><option>-- Chọn chuyên khoa --</option><option>Tim mạch</option><option>Nhi khoa</option><option>Thần kinh</option><option>Da liễu</option></select>
          <div class="form-hint">Dùng để lọc ca làm việc khi bệnh nhân chọn dịch vụ</div>
        </div>
        <div class="form-group"><label>Mô tả dịch vụ</label><textarea class="form-control" placeholder="Mô tả chi tiết hiển thị cho bệnh nhân..."></textarea></div>
        <div class="form-row">
          <div class="form-group">
            <label>Thời gian ước tính (phút)</label>
            <input type="number" class="form-control" placeholder="VD: 30" min="5" step="5">
            <div class="form-hint">Hint để hệ thống chọn slot phù hợp</div>
          </div>
          <div class="form-group" style="justify-content:flex-end;padding-top:22px">
            <div style="display:flex;align-items:center;gap:12px">
              <label class="toggle"><input type="checkbox" checked><span class="toggle-slider"></span></label>
              <span style="font-size:13.5px;font-weight:500">Hiển thị cho bệnh nhân</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add-dv')">Hủy</button>
      <button class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm dịch vụ</button>
    </div>
  </div>
</div>


<script>
function addService() {
    const form = document.getElementById('add-service-form');
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    showToast('Dịch vụ đã được thêm thành công!', 'success');
    hideModal('modal-add-service');
    form.reset();
}

function editService(id) {
    showToast('Chức năng chỉnh sửa đang phát triển', 'info');
}

function deleteService(id) {
    if (confirm('Bạn có chắc muốn xóa dịch vụ này?')) {
        showToast('Dịch vụ đã được xóa!', 'success');
    }
}

// Search functionality
document.getElementById('search-services')?.addEventListener('input', function() {
    const query = this.value.toLowerCase();
    const rows = document.querySelectorAll('#services-table tr');
    
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(query) ? '' : 'none';
    });
});

// Filter functionality
document.getElementById('filter-specialty')?.addEventListener('change', filterServices);
document.getElementById('filter-status')?.addEventListener('change', filterServices);

function filterServices() {
    const specialty = document.getElementById('filter-specialty').value;
    const status = document.getElementById('filter-status').value;
    const rows = document.querySelectorAll('#services-table tr');
    
    rows.forEach(row => {
        let show = true;
        
        if (specialty && !row.textContent.includes(specialty)) {
            show = false;
        }
        
        if (status) {
            const checkbox = row.querySelector('input[type="checkbox"]');
            if (checkbox) {
                const isChecked = checkbox.checked;
                if ((status === 'true' && !isChecked) || (status === 'false' && isChecked)) {
                    show = false;
                }
            }
        }
        
        row.style.display = show ? '' : 'none';
    });
}
</script>
