@page
@model ClinicBooking.Web.Pages.BenhNhan.DatLichModel
@{
    ViewData["Title"] = "Đặt lịch khám";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Đặt lịch khám</h1>
        <div class="page-subtitle">Chọn chuyên khoa, ngày khám và ca phù hợp.</div>
    </div>
    <div class="action-bar">
        <a href="/BenhNhan/ChuyenKhoa" class="btn btn-secondary">
            <i class="ph ph-stethoscope"></i> Xem chuyên khoa
        </a>
    </div>
</div>

@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="panel-grid-2">
    <div class="section-stack">
        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-calendar-blank"></i> Chọn ngày khám</span>
            </div>
            <div style="padding: var(--space-4);">
                <form method="get" class="filter-bar">
                    <div class="form-group" style="margin:0; min-width:240px;">
                        <label class="form-label" for="ngay">Ngày khám</label>
                        <input type="date" class="form-input" id="ngay" name="ngay"
                               value="@Model.NgayChon.ToString("yyyy-MM-dd")"
                               min="@DateOnly.FromDateTime(DateTime.Now.AddDays(1)).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="filter-actions">
                        <button type="submit" class="btn btn-secondary">
                            <i class="ph ph-magnifying-glass"></i> Xem ca trống
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-clock"></i> Ca làm việc ngày @Model.NgayChon.ToString("dd/MM/yyyy")</span>
            </div>

            @if (!Model.DanhSachCa.Any())
            {
                <div class="empty-state" style="padding: var(--space-6);">
                    <div class="empty-state-icon"><i class="ph ph-calendar-x"></i></div>
                    <p>Không có ca làm việc trống cho ngày này.<br/>Vui lòng chọn ngày khác.</p>
                </div>
            }
            else
            {
                <div style="padding: var(--space-4);" class="section-stack">
                    @foreach (var ca in Model.DanhSachCa)
                    {
                        <label class="slot-card @(Model.IdCaLamViec == ca.IdCaLamViec ? "slot-card--selected" : "")">
                            <input type="radio" name="IdCaLamViec" value="@ca.IdCaLamViec"
                                   @(Model.IdCaLamViec == ca.IdCaLamViec ? "checked" : "") />
                            <div class="slot-card-body">
                                <div class="slot-card-top">
                                    <strong>@ca.GioBatDau.ToString("HH:mm") – @ca.GioKetThuc.ToString("HH:mm")</strong>
                                    <span class="badge badge-success">Còn chỗ</span>
                                </div>
                                <div class="slot-card-meta">@ca.TenChuyenKhoa · Phòng @ca.MaPhong</div>
                                <div class="slot-card-meta">Mỗi slot @ca.ThoiGianSlot phút</div>
                            </div>
                        </label>
                    }
                </div>
            }
        </div>
    </div>

    <div class="section-stack">
        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-first-aid"></i> Dịch vụ khám</span>
            </div>
            <div style="padding: var(--space-4);">
                @if (!Model.DanhSachDichVu.Any())
                {
                    <p style="color:var(--color-text-secondary);">Chưa có dịch vụ nào.</p>
                }
                else
                {
                    <select class="form-select" asp-for="IdDichVu" style="width:100%;" required>
                        <option value="0">— Chọn dịch vụ —</option>
                        @foreach (var dv in Model.DanhSachDichVu)
                        {
                            <option value="@dv.IdDichVu" selected="@(Model.IdDichVu == dv.IdDichVu ? "selected" : null)">
                                @dv.TenDichVu
                                @if (!string.IsNullOrEmpty(dv.TenChuyenKhoa))
                                {
                                    <text> (@dv.TenChuyenKhoa)</text>
                                }
                            </option>
                        }
                    </select>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="ph ph-note-pencil"></i> Thông tin bổ sung</span>
            </div>
            <div style="padding: var(--space-4);" class="section-stack">
                <div class="form-group">
                    <label class="form-label">Triệu chứng / lý do khám</label>
                    <textarea class="form-input" asp-for="TrieuChung" rows="3" placeholder="Mô tả triệu chứng hoặc lý do muốn khám..."></textarea>
                </div>
            </div>
        </div>

        <div class="action-bar">
            <a href="/BenhNhan/DanhSachLichHen" class="btn btn-secondary">Huỷ bỏ</a>
            <button type="submit" class="btn btn-primary" formmethod="post" formaction="?handler=Post&ngay=@Model.NgayChon.ToString("yyyy-MM-dd")" @(!Model.DanhSachCa.Any() ? "disabled" : "")>
                <i class="ph ph-calendar-check"></i> Xác nhận đặt lịch
            </button>
        </div>
    </div>
</div>

@section Scripts {
<style>
.slot-card {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    cursor: pointer;
    transition: 0.15s ease;
    background: #fff;
}
.slot-card:hover { border-color: var(--color-primary-mid); background: var(--color-primary-light); }
.slot-card--selected { border-color: var(--color-primary); background: var(--color-active-bg); }
.slot-card input { margin-top: 4px; }
.slot-card-body { flex: 1; display: grid; gap: 4px; }
.slot-card-top { display: flex; justify-content: space-between; gap: 12px; align-items: center; }
.slot-card-meta { color: var(--color-text-secondary); font-size: 12px; }
</style>
}
