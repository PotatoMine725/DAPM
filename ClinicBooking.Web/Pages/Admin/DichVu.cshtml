@page
@using System.Text.Json
@model ClinicBooking.Web.Pages.Admin.DichVuModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý dịch vụ - MedAdmin";
    ViewData["PageName"] = "dichvu";
    ViewData["PageTitle"] = "Quản lý dịch vụ";
}

<div class="section-title">Quản lý dịch vụ</div>
<div class="section-sub">Danh mục dịch vụ khám / xét nghiệm theo chuyên khoa</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div style="background:var(--success-bg);border:1px solid #b7e0a0;border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:var(--success);display:flex;align-items:center;gap:10px">
        <i class="fa-solid fa-circle-check"></i><div>@successMsg</div>
    </div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div style="background:var(--danger-bg);border:1px solid #f5c6c6;border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:var(--danger);display:flex;align-items:center;gap:10px">
        <i class="fa-solid fa-circle-exclamation"></i><div>@errorMsg</div>
    </div>
}

<div class="card">
    <div class="card-header">
        <div class="card-title">Danh sách dịch vụ (@Model.DanhSach.Count)</div>
        <button class="btn btn-primary" onclick="moModalTao()"><i class="fa-solid fa-plus"></i> Thêm dịch vụ</button>
    </div>

    <form method="get" class="toolbar">
        <div class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="text" name="tuKhoa" value="@Model.TuKhoa" placeholder="Tìm theo tên dịch vụ..."></div>
        <select class="form-control" style="width:200px" name="idChuyenKhoa" onchange="this.form.submit()">
            <option value="">Tất cả chuyên khoa</option>
            @foreach (var ck in Model.DanhSachChuyenKhoa)
            {
                var sel = Model.IdChuyenKhoaLoc == ck.IdChuyenKhoa ? "selected" : null;
                <option value="@ck.IdChuyenKhoa" selected="@sel">@ck.TenChuyenKhoa</option>
            }
        </select>
        <select class="form-control" style="width:160px" name="hienThi" onchange="this.form.submit()">
            <option value="">Tất cả</option>
            <option value="true" selected="@(Model.HienThiLoc == true ? "selected" : null)">Hiển thị</option>
            <option value="false" selected="@(Model.HienThiLoc == false ? "selected" : null)">Ẩn</option>
        </select>
        <button type="submit" class="btn btn-ghost btn-sm">Lọc</button>
    </form>
</div>

<div class="card">
    <table>
        <thead>
            <tr><th>Tên dịch vụ</th><th>Chuyên khoa</th><th>Mô tả</th><th>Ước tính (phút)</th><th>Hiển thị</th><th>Thao tác</th></tr>
        </thead>
        <tbody>
            @if (Model.DanhSach.Count == 0)
            {
                <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-secondary)">Chưa có dịch vụ nào.</td></tr>
            }
            @foreach (var dv in Model.DanhSach)
            {
                <tr>
                    <td><strong>@dv.TenDichVu</strong></td>
                    <td>@dv.TenChuyenKhoa</td>
                    <td style="font-size:12px;color:var(--text-secondary);max-width:280px">@dv.MoTa</td>
                    <td>@(dv.ThoiGianUocTinh?.ToString() ?? "—")</td>
                    <td>
                        @if (dv.HienThi)
                        {
                            <span class="badge badge-success">Có</span>
                        }
                        else
                        {
                            <span class="badge badge-warning">Ẩn</span>
                        }
                    </td>
                    <td>
                        <div class="action-btns" style="display:flex;gap:6px">
                            <button class="btn btn-ghost btn-sm" title="Sửa" onclick='moModalSua(@Html.Raw(JsonSerializer.Serialize(dv)))'><i class="fa-solid fa-pen"></i></button>
                            <form method="post" asp-page-handler="Xoa" style="display:inline" onsubmit="return confirm('Xoá dịch vụ @dv.TenDichVu?');">
                                <input type="hidden" name="IdDichVuXoa" value="@dv.IdDichVu" />
                                <button type="submit" class="btn btn-ghost btn-sm" title="Xoá" style="color:var(--danger)"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Tạo -->
<div class="modal-overlay" id="modal-add-dv">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fa-solid fa-briefcase-medical" style="color:var(--primary);margin-right:8px"></i>Thêm dịch vụ</div>
      <div class="modal-close" onclick="closeModal('modal-add-dv')"><i class="fa-solid fa-times"></i></div>
    </div>
    <form method="post" asp-page-handler="Tao">
      <div class="modal-body">
        <div class="form-group"><label>Chuyên khoa *</label>
            <select class="form-control" name="IdChuyenKhoaInput" required>
                <option value="">Chọn chuyên khoa</option>
                @foreach (var ck in Model.DanhSachChuyenKhoa)
                {
                    <option value="@ck.IdChuyenKhoa">@ck.TenChuyenKhoa</option>
                }
            </select>
        </div>
        <div class="form-group"><label>Tên dịch vụ *</label><input type="text" class="form-control" name="TenDichVu" required maxlength="150"></div>
        <div class="form-group"><label>Mô tả</label><textarea class="form-control" name="MoTa" maxlength="500"></textarea></div>
        <div class="form-group"><label>Thời gian ước tính (phút)</label><input type="number" class="form-control" name="ThoiGianUocTinh" min="1" max="240"></div>
        <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="HienThi" value="true" checked /> Hiển thị cho bệnh nhân</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('modal-add-dv')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Sửa -->
<div class="modal-overlay" id="modal-edit-dv">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fa-solid fa-pen" style="color:var(--primary);margin-right:8px"></i>Sửa dịch vụ</div>
      <div class="modal-close" onclick="closeModal('modal-edit-dv')"><i class="fa-solid fa-times"></i></div>
    </div>
    <form method="post" asp-page-handler="CapNhat">
      <input type="hidden" name="IdDichVuSua" id="dv-id" />
      <div class="modal-body">
        <div class="form-group"><label>Chuyên khoa *</label>
            <select class="form-control" name="IdChuyenKhoaInput" id="dv-ck" required>
                @foreach (var ck in Model.DanhSachChuyenKhoa)
                {
                    <option value="@ck.IdChuyenKhoa">@ck.TenChuyenKhoa</option>
                }
            </select>
        </div>
        <div class="form-group"><label>Tên dịch vụ *</label><input type="text" class="form-control" name="TenDichVu" id="dv-ten" required maxlength="150"></div>
        <div class="form-group"><label>Mô tả</label><textarea class="form-control" name="MoTa" id="dv-mota" maxlength="500"></textarea></div>
        <div class="form-group"><label>Thời gian ước tính (phút)</label><input type="number" class="form-control" name="ThoiGianUocTinh" id="dv-tg" min="1" max="240"></div>
        <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="HienThi" id="dv-hien" value="true" /> Hiển thị cho bệnh nhân</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit-dv')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu</button>
      </div>
    </form>
  </div>
</div>

<script>
function moModalTao() {
    document.querySelector('#modal-add-dv form').reset();
    openModal('modal-add-dv');
}
function moModalSua(dv) {
    document.getElementById('dv-id').value = dv.idDichVu;
    document.getElementById('dv-ck').value = dv.idChuyenKhoa;
    document.getElementById('dv-ten').value = dv.tenDichVu || '';
    document.getElementById('dv-mota').value = dv.moTa || '';
    document.getElementById('dv-tg').value = dv.thoiGianUocTinh ?? '';
    document.getElementById('dv-hien').checked = !!dv.hienThi;
    openModal('modal-edit-dv');
}
</script>
