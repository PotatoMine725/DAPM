@page
@model ClinicBooking.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Bảng điều khiển Admin";
}

<div class="page-header">
    <h1 class="page-title">Bảng điều khiển Admin</h1>
    <span style="font-size:13px; color:var(--color-text-secondary);">
        <i class="ph ph-shield-check"></i> Vai trò: quản trị viên
    </span>
</div>

<div class="card" style="border-left: 4px solid var(--color-warning-text);">
    <div class="card-header">
        <span class="card-title">
            <i class="ph ph-warning-circle"></i>
            Giao diện admin đang được phát triển
        </span>
    </div>
    <div style="padding: 16px 20px; line-height: 1.6;">
        <p>
            Module <strong>Quản trị hệ thống</strong> (do thành viên Module 4 phụ trách) hiện chưa có UI hoàn chỉnh.
            Trang này là placeholder để tài khoản admin có landing page riêng, không trùng với lễ tân.
        </p>
        <p>Các chức năng dự kiến:</p>
        <ul style="padding-left: 20px;">
            <li>Duyệt ca làm việc của bác sĩ</li>
            <li>Quản lý tài khoản nhân viên</li>
            <li>Quản lý chuyên khoa, dịch vụ, phòng</li>
            <li>Báo cáo thống kê doanh thu, lượt khám</li>
            <li>Cấu hình hệ thống (mẫu thông báo, giới hạn đặt lịch)</li>
        </ul>
        <p style="margin-top: 16px;">
            Tham chiếu: <code>docs/phan-chia-module-va-huong-dan-du-an.md</code> — Module 4.
        </p>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(3,1fr); margin-top: 20px;">
    <a href="/LeTan/Dashboard" class="stat-card" style="text-decoration:none; color:inherit;">
        <div class="stat-icon" style="background:var(--color-primary-light); color:var(--color-primary);">
            <i class="ph ph-user-gear"></i>
        </div>
        <div>
            <div class="stat-value" style="font-size:16px;">Xem giao diện lễ tân</div>
            <div class="stat-label">Tạm dùng chung trong lúc chờ UI admin</div>
        </div>
    </a>
    <a href="/BacSi/HangCho" class="stat-card" style="text-decoration:none; color:inherit;">
        <div class="stat-icon" style="background:var(--color-active-bg); color:var(--color-active-text);">
            <i class="ph ph-stethoscope"></i>
        </div>
        <div>
            <div class="stat-value" style="font-size:16px;">Hàng chờ bác sĩ</div>
            <div class="stat-label">Theo dõi luồng khám</div>
        </div>
    </a>
    <a href="/Admin/QuanLyThuoc" class="stat-card" style="text-decoration:none; color:inherit;">
        <div class="stat-icon" style="background:var(--color-success-bg); color:var(--color-success-text);">
            <i class="ph ph-pill"></i>
        </div>
        <div>
            <div class="stat-value" style="font-size:16px;">Quản lý thuốc</div>
            <div class="stat-label">Danh mục thuốc Module 3</div>
        </div>
    </a>
    <form method="post" asp-page="/Auth/DangXuat" class="stat-card" style="border:none; background:var(--color-danger-bg); cursor:pointer;">
        <button type="submit" style="all:unset; display:contents;">
            <div class="stat-icon" style="background:var(--color-danger-text); color:white;">
                <i class="ph ph-sign-out"></i>
            </div>
            <div>
                <div class="stat-value" style="font-size:16px;">Đăng xuất</div>
                <div class="stat-label">Kết thúc phiên admin</div>
            </div>
        </button>
    </form>
</div>
