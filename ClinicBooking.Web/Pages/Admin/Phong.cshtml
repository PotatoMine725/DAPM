@page
@using System.Text.Json
@model ClinicBooking.Web.Pages.Admin.PhongModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý phòng khám - MedAdmin";
    ViewData["PageName"] = "phong";
    ViewData["PageTitle"] = "Quản lý phòng khám";
}

<div class="section-title">Quản lý phòng khám</div>
<div class="section-sub">Cấu hình thông tin, trang bị và trạng thái các phòng khám</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div style="background:var(--success-bg);border:1px solid #b7e0a0;border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:var(--success);display:flex;align-items:center;gap:10px">
        <i class="fa-solid fa-circle-check"></i><div>@successMsg</div>
    </div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div style="background:var(--danger-bg);border:1px solid #f5c6c6;border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:var(--danger);display:flex;align-items:center;gap:10px">
        <i class="fa-solid fa-circle-exclamation"></i><div>@errorMsg</div>
    </div>
}

<form method="get" class="toolbar">
  <div class="toolbar-left" style="display:flex;gap:8px;flex-wrap:wrap">
    <div class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="text" name="tuKhoa" value="@Model.TuKhoa" placeholder="Tìm mã phòng, tên phòng..."></div>
    <select class="filter-select" name="trangThai" onchange="this.form.submit()">
      <option value="">Tất cả trạng thái</option>
      <option value="true" selected="@(Model.TrangThaiLoc == true ? "selected" : null)">Đang hoạt động</option>
      <option value="false" selected="@(Model.TrangThaiLoc == false ? "selected" : null)">Ngừng</option>
    </select>
    <button type="submit" class="btn btn-ghost btn-sm"><i class="fa-solid fa-magnifying-glass"></i> Lọc</button>
  </div>
  <div class="toolbar-right">
    <button type="button" class="btn btn-primary" onclick="moModalTao()"><i class="fa-solid fa-plus"></i> Thêm phòng</button>
  </div>
</form>

<div class="card">
  <table>
    <thead>
      <tr><th>Mã phòng</th><th>Tên phòng</th><th>Sức chứa</th><th>Trang bị</th><th>Trạng thái</th><th>Thao tác</th></tr>
    </thead>
    <tbody>
      @if (Model.DanhSach.Count == 0)
      {
          <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-secondary)">Chưa có phòng nào.</td></tr>
      }
      @foreach (var p in Model.DanhSach)
      {
          <tr>
              <td><strong>@p.MaPhong</strong></td>
              <td>@p.TenPhong</td>
              <td>@(p.SucChua.HasValue ? $"{p.SucChua} BN" : "—")</td>
              <td style="font-size:12px;color:var(--text-secondary);max-width:240px">@p.TrangBi</td>
              <td>
                  @if (p.TrangThai)
                  {
                      <span class="badge badge-success">Hoạt động</span>
                  }
                  else
                  {
                      <span class="badge badge-warning">Ngừng</span>
                  }
              </td>
              <td>
                  <div class="action-btns" style="display:flex;gap:6px">
                      <button class="btn btn-ghost btn-sm" title="Sửa" onclick='moModalSua(@Html.Raw(JsonSerializer.Serialize(p)))'><i class="fa-solid fa-pen"></i></button>
                      <form method="post" asp-page-handler="Xoa" style="display:inline" onsubmit="return confirm('Xoá phòng @p.MaPhong?');">
                          <input type="hidden" name="IdPhongXoa" value="@p.IdPhong" />
                          <button type="submit" class="btn btn-ghost btn-sm" title="Xoá" style="color:var(--danger)"><i class="fa-solid fa-trash"></i></button>
                      </form>
                  </div>
              </td>
          </tr>
      }
    </tbody>
  </table>
</div>

<!-- Modal Tạo -->
<div class="modal-overlay" id="modal-add-phong">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fa-solid fa-door-open" style="color:var(--primary);margin-right:8px"></i>Thêm phòng khám</div>
      <div class="modal-close" onclick="closeModal('modal-add-phong')"><i class="fa-solid fa-times"></i></div>
    </div>
    <form method="post" asp-page-handler="Tao">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div class="form-group"><label>Mã phòng *</label><input type="text" class="form-control" name="MaPhong" required maxlength="20"></div>
            <div class="form-group"><label>Tên phòng *</label><input type="text" class="form-control" name="TenPhong" required maxlength="150"></div>
          </div>
          <div class="form-group"><label>Sức chứa tối đa (bệnh nhân)</label><input type="number" class="form-control" name="SucChua" min="1"></div>
          <div class="form-group"><label>Trang bị / Thiết bị</label><textarea class="form-control" name="TrangBi" maxlength="500"></textarea></div>
          <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="TrangThai" value="true" checked /> Phòng đang hoạt động</label>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('modal-add-phong')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm phòng</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Sửa -->
<div class="modal-overlay" id="modal-edit-phong">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fa-solid fa-pen" style="color:var(--primary);margin-right:8px"></i>Chỉnh sửa phòng</div>
      <div class="modal-close" onclick="closeModal('modal-edit-phong')"><i class="fa-solid fa-times"></i></div>
    </div>
    <form method="post" asp-page-handler="CapNhat">
      <input type="hidden" name="IdPhongSua" id="edit-id" />
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div class="form-group"><label>Mã phòng *</label><input type="text" class="form-control" name="MaPhong" id="edit-ma" required maxlength="20"></div>
            <div class="form-group"><label>Tên phòng *</label><input type="text" class="form-control" name="TenPhong" id="edit-ten" required maxlength="150"></div>
          </div>
          <div class="form-group"><label>Sức chứa tối đa</label><input type="number" class="form-control" name="SucChua" id="edit-suc" min="1"></div>
          <div class="form-group"><label>Trang bị / Thiết bị</label><textarea class="form-control" name="TrangBi" id="edit-tb" maxlength="500"></textarea></div>
          <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="TrangThai" id="edit-tt" value="true" /> Phòng đang hoạt động</label>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit-phong')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi</button>
      </div>
    </form>
  </div>
</div>

<script>
function moModalTao() {
    const form = document.querySelector('#modal-add-phong form');
    form.reset();
    openModal('modal-add-phong');
}

function moModalSua(p) {
    document.getElementById('edit-id').value = p.idPhong;
    document.getElementById('edit-ma').value = p.maPhong || '';
    document.getElementById('edit-ten').value = p.tenPhong || '';
    document.getElementById('edit-suc').value = p.sucChua ?? '';
    document.getElementById('edit-tb').value = p.trangBi || '';
    document.getElementById('edit-tt').checked = !!p.trangThai;
    openModal('modal-edit-phong');
}
</script>
