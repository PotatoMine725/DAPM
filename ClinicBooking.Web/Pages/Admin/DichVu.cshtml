                        <button class="btn btn-ghost btn-sm" onclick="editService(3)">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteService(3)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="color:var(--text-disabled)">#4</td>
                <td><strong>Điện não đồ</strong></td>
