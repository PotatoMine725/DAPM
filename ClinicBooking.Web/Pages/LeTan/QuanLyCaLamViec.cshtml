@page
@model ClinicBooking.Web.Pages.LeTan.QuanLyCaLamViecModel
@{
    ViewData["Title"] = "Quản lý ca làm việc";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý ca làm việc</h1>
        <div class="page-subtitle">Duyệt, xoá và theo dõi các ca làm việc đã tạo.</div>
    </div>
</div>

<div class="stats-grid stats-grid--responsive" style="margin-bottom: var(--space-5);">
    <div class="stat-card"><div class="stat-icon" style="background:var(--color-primary-light); color:var(--color-primary);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5h16v14H4z" stroke="currentColor" stroke-width="2"/><path d="M4 9h16" stroke="currentColor" stroke-width="2"/><path d="M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></div><div><div class="stat-value">@Model.TongSoCa</div><div class="stat-label">Tổng số ca</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:var(--color-success-bg); color:var(--color-success-text);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7 9 18l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="stat-value">@Model.SoCaDaDuyet</div><div class="stat-label">Đã duyệt</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:var(--color-warning-bg); color:var(--color-warning-text);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 9v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M12 17h.01" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M10.29 3.86 1.82 18A2 2 0 0 0 3.54 21h16.92a2 2 0 0 0 1.72-3L13.71 3.86a2 2 0 0 0-3.42 0Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></div><div><div class="stat-value">@Model.SoCaChoDuyet</div><div class="stat-label">Chờ duyệt</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:var(--color-active-bg); color:var(--color-active-text);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 19h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M8 5h8v10H8z" stroke="currentColor" stroke-width="2"/><path d="M10 9h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></div><div><div class="stat-value">@Model.SoCaConTrong</div><div class="stat-label">Còn trống</div></div></div>
</div>

<div class="card section-stack">
    <div class="card-header"><span class="card-title"><i class="ph ph-funnel"></i> Bộ lọc</span></div>
    <form method="get" class="form-grid-2">
        <div class="form-group"><label class="form-label">Chuyên khoa</label><select class="form-select" name="idChuyenKhoa"><option value="">Tất cả</option>@foreach (var item in Model.DanhSachChuyenKhoa){<option value="@item.IdChuyenKhoa">@item.TenChuyenKhoa</option>}</select></div>
        <div class="form-group"><label class="form-label">Phòng</label><select class="form-select" name="idPhong"><option value="">Tất cả</option>@foreach (var item in Model.DanhSachPhong){<option value="@item.IdPhong">@item.MaPhong</option>}</select></div>
        <div class="form-group"><label class="form-label">Từ ngày</label><input class="form-input" type="date" name="tuNgay" /></div>
        <div class="form-group"><label class="form-label">Đến ngày</label><input class="form-input" type="date" name="denNgay" /></div>
        <div class="form-group"><label class="form-label">Còn trống</label><select class="form-select" name="conTrong"><option value="">Tất cả</option><option value="true">Còn trống</option><option value="false">Hết chỗ</option></select></div>
        <div class="form-group" style="align-self:end;"><button class="btn btn-primary" type="submit">Lọc</button></div>
    </form>
</div>

<div class="card section-stack">
    <div class="card-header"><span class="card-title"><i class="ph ph-calendar-dots"></i> Danh sách ca</span></div>
    <table class="data-table">
        <thead><tr><th>Bác sĩ</th><th>Ngày</th><th>Giờ</th><th>Chuyên khoa</th><th>Phòng</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
        <tbody>
        @foreach (var item in Model.DanhSach)
        {
            <tr>
                <td><strong>@item.HoTenBacSi</strong></td>
                <td>@item.NgayLamViec.ToString("dd/MM/yyyy")</td>
                <td>@item.GioBatDau.ToString("HH:mm") - @item.GioKetThuc.ToString("HH:mm")</td>
                <td>@item.TenChuyenKhoa</td>
                <td>@item.MaPhong</td>
                <td>@item.TrangThaiDuyet</td>
                <td class="table-actions">
                    <form method="post" asp-page-handler="Duyet" class="inline-form"><input type="hidden" name="idCaLamViec" value="@item.IdCaLamViec" /><input type="hidden" name="chapNhan" value="true" /><button class="btn btn-sm btn-primary" type="submit">Duyệt</button></form>
                    <form method="post" asp-page-handler="Xoa" class="inline-form"><input type="hidden" name="idCaLamViec" value="@item.IdCaLamViec" /><button class="btn btn-sm btn-danger" type="submit">Xóa</button></form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>