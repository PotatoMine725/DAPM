@page
@model ClinicBooking.Web.Pages.Admin.DichVuModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý dịch vụ - MedAdmin";
    ViewData["PageName"] = "dichvu";
    ViewData["PageTitle"] = "Quản lý dịch vụ";
}

<div class="section-title">Quản lý dịch vụ</div>
<div class="section-sub">Cấu hình các dịch vụ khám, chẩn đoán theo từng chuyên khoa</div>

<!-- Summary -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px">
  <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:12px">
    <div style="width:38px;height:38px;border-radius:var(--radius-sm);background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary)"><i class="fa-solid fa-syringe"></i></div>
    <div><div style="font-family:'Lexend';font-size:20px;font-weight:700">18</div><div style="font-size:12px;color:var(--text-secondary)">Tổng dịch vụ</div></div>
  </div>
  <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:12px">
    <div style="width:38px;height:38px;border-radius:var(--radius-sm);background:var(--success-bg);display:flex;align-items:center;justify-content:center;color:var(--success)"><i class="fa-solid fa-eye"></i></div>
    <div><div style="font-family:'Lexend';font-size:20px;font-weight:700">15</div><div style="font-size:12px;color:var(--text-secondary)">Đang hiển thị</div></div>
  </div>
  <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:12px">
    <div style="width:38px;height:38px;border-radius:var(--radius-sm);background:var(--danger-bg);display:flex;align-items:center;justify-content:center;color:var(--danger)"><i class="fa-solid fa-eye-slash"></i></div>
    <div><div style="font-family:'Lexend';font-size:20px;font-weight:700">3</div><div style="font-size:12px;color:var(--text-secondary)">Đã ẩn</div></div>
  </div>
  <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:12px">
    <div style="width:38px;height:38px;border-radius:var(--radius-sm);background:var(--warning-bg);display:flex;align-items:center;justify-content:center;color:var(--warning)"><i class="fa-solid fa-stethoscope"></i></div>
    <div><div style="font-family:'Lexend';font-size:20px;font-weight:700">4</div><div style="font-size:12px;color:var(--text-secondary)">Chuyên khoa</div></div>
  </div>
</div>

<!-- Toolbar -->
<div class="toolbar">
  <div class="toolbar-left">
    <div class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="text" placeholder="Tìm tên dịch vụ..."></div>
    <select class="filter-select">
      <option value="">Tất cả chuyên khoa</option><option>Tim mạch</option><option>Nhi khoa</option><option>Thần kinh</option><option>Da liễu</option>
    </select>
    <select class="filter-select">
      <option value="">Tất cả trạng thái</option><option>Đang hiển thị</option><option>Đã ẩn</option>
    </select>
  </div>
  <div class="toolbar-right">
    <button class="btn btn-primary" onclick="openModal('modal-add-dv')"><i class="fa-solid fa-plus"></i> Thêm dịch vụ</button>
  </div>
</div>

