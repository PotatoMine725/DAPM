        </thead>
        <tbody id="services-table">
            <tr>
                <td style="color:var(--text-disabled)">#1</td>
                <td><strong>Khám tổng quát Tim mạch</strong></td>
                <td><span class="badge badge-primary">Tim mạch</span></td>
                <td><span class="badge badge-neutral">30 phút</span></td>
                <td style="font-size:12.5px;color:var(--text-secondary);max-width:180px">Đo ECG, siêu âm tim cơ bản</td>
                <td>
                    <div style="font-size:12px;font-weight:600;margin-bottom:3px">142</div>
                    <div class="progress" style="width:80px"><div class="progress-bar" style="width:83%"></div></div>
                </td>
                <td>
                    <label class="toggle">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </td>
                <td>
                    <div class="action-btns">
                        <button class="btn btn-ghost btn-sm" onclick="editService(1)">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteService(1)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="color:var(--text-disabled)">#2</td>
                <td><strong>Siêu âm ổ bụng</strong></td>
                <td><span class="badge badge-primary">Tim mạch</span></td>
                <td><span class="badge badge-neutral">20 phút</span></td>
                <td style="font-size:12.5px;color:var(--text-secondary);max-width:180px">Siêu âm chẩn đoán ổ bụng toàn diện</td>
                <td>
                    <div style="font-size:12px;font-weight:600;margin-bottom:3px">98</div>
                    <div class="progress" style="width:80px"><div class="progress-bar" style="width:57%;background:var(--success)"></div></div>
                </td>
                <td>
                    <label class="toggle">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </td>
                <td>
                    <div class="action-btns">
                        <button class="btn btn-ghost btn-sm" onclick="editService(2)">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteService(2)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="color:var(--text-disabled)">#3</td>
                <td><strong>Khám Nhi tổng quát</strong></td>
                <td><span class="badge" style="background:#e8f5e9;color:#2e7d32">Nhi khoa</span></td>
                <td><span class="badge badge-neutral">15 phút</span></td>
                <td style="font-size:12.5px;color:var(--text-secondary);max-width:180px">Khám sức khỏe định kỳ trẻ em</td>
                <td>
