@page
@model ClinicBooking.Web.Pages.BenhNhan.ToaThuocModel
@{
    ViewData["Title"] = "Đơn thuốc của tôi";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Đơn thuốc của tôi</h1>
        <div class="page-subtitle" style="margin-top:var(--space-1); color:var(--color-text-secondary); font-size:13px;">
            Xem các đơn thuốc đã được bác sĩ kê cho bạn.
        </div>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="margin-bottom:var(--space-4);">
        <i class="ph ph-warning-circle"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="card">
    @if (!Model.DanhSachToa.Any())
    {
        <div class="empty-state" style="padding:var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-prescription"></i></div>
            <p>Bạn chưa có đơn thuốc nào.</p>
            <a href="/BenhNhan/DatLich" class="btn btn-primary btn-sm" style="margin-top:var(--space-3);">
                <i class="ph ph-calendar-plus"></i> Đặt lịch khám
            </a>
        </div>
    }
    else
    {
        <div class="card-header">
            <span class="card-title">
                <i class="ph ph-pill"></i> 
                @Model.ToaNhomTheoHoSo.Count() đơn thuốc (Trang @Model.SoTrang)
            </span>
        </div>

        <div class="toa-thuoc-list">
            @foreach (var nhom in Model.ToaNhomTheoHoSo)
            {
                <div class="toa-thuoc-item">
                    <div class="toa-thuoc-header">
                        <div>
                            <div class="toa-thuoc-date">
                                <i class="ph ph-calendar-blank"></i>
                                Đơn ngày @nhom.Key.NgayKham.ToString("dd/MM/yyyy")
                            </div>
                            <div class="toa-thuoc-code">
                                Mã lịch hẹn: <span class="table-code">@nhom.Key.MaLichHen</span>
                            </div>
                        </div>
                        <div class="toa-thuoc-count">
                            <i class="ph ph-pill"></i>
                            @nhom.Count() thuốc
                        </div>
                    </div>

                    <div class="toa-thuoc-drugs">
                        @{
                            var stt = 1;
                        }
                        @foreach (var thuoc in nhom)
                        {
                            <div class="toa-thuoc-drug">
                                <div class="toa-thuoc-drug-number">@stt</div>
                                <div class="toa-thuoc-drug-content">
                                    <div class="toa-thuoc-drug-name">
                                        <i class="ph ph-pill"></i>
                                        @thuoc.TenThuoc
                                    </div>
                                    
                                    <div class="toa-thuoc-drug-details">
                                        @if (!string.IsNullOrWhiteSpace(thuoc.LieuLuong))
                                        {
                                            <div class="toa-thuoc-drug-field">
                                                <label>Liều lượng:</label>
                                                <span>@thuoc.LieuLuong</span>
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrWhiteSpace(thuoc.CachDung))
                                        {
                                            <div class="toa-thuoc-drug-field">
                                                <label>Cách dùng:</label>
                                                <span>@thuoc.CachDung</span>
                                            </div>
                                        }
                                        
                                        @if (thuoc.SoNgayDung.HasValue)
                                        {
                                            <div class="toa-thuoc-drug-field">
                                                <label>Số ngày dùng:</label>
                                                <span>@thuoc.SoNgayDung ngày</span>
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrWhiteSpace(thuoc.GhiChu))
                                        {
                                            <div class="toa-thuoc-drug-field">
                                                <label>Ghi chú:</label>
                                                <span>@thuoc.GhiChu</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                            stt++;
                        }
                    </div>
                </div>
            }
        </div>

        @if (Model.DanhSachToa.Count >= 10)
        {
            <div style="display:flex; justify-content:center; gap:var(--space-2); padding:var(--space-4); border-top:1px solid var(--color-border);">
                @if (Model.SoTrang > 1)
                {
                    <a href="/BenhNhan/ToaThuoc?soTrang=@(Model.SoTrang - 1)" class="btn btn-sm btn-secondary">
                        <i class="ph ph-caret-left"></i> Trang trước
                    </a>
                }
                <span class="btn btn-sm btn-primary" style="pointer-events:none;">
                    Trang @Model.SoTrang
                </span>
                <a href="/BenhNhan/ToaThuoc?soTrang=@(Model.SoTrang + 1)" class="btn btn-sm btn-secondary">
                    Trang sau <i class="ph ph-caret-right"></i>
                </a>
            </div>
        }
    }
</div>

@section Scripts {
<style>
    .toa-thuoc-list {
        display: grid;
        gap: 0;
    }

    .toa-thuoc-item {
        padding: var(--space-4);
        border-bottom: 1px solid var(--color-border);
    }

    .toa-thuoc-item:last-child {
        border-bottom: none;
    }

    .toa-thuoc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-3);
        margin-bottom: var(--space-4);
        padding-bottom: var(--space-3);
        border-bottom: 2px solid var(--color-border);
        flex-wrap: wrap;
    }

    .toa-thuoc-date {
        font-size: 16px;
        font-weight: 600;
        color: var(--color-text-primary);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .toa-thuoc-date i {
        font-size: 18px;
        color: var(--color-primary);
    }

    .toa-thuoc-code {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin-top: 4px;
    }

    .toa-thuoc-count {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        font-weight: 600;
        color: var(--color-primary);
        padding: 6px 12px;
        background: var(--color-primary-bg, #eff6ff);
        border-radius: 6px;
    }

    .toa-thuoc-count i {
        font-size: 18px;
    }

    .toa-thuoc-drugs {
        display: grid;
        gap: var(--space-3);
    }

    .toa-thuoc-drug {
        display: flex;
        gap: var(--space-3);
        padding: var(--space-3);
        background: var(--color-neutral-bg, #f9fafb);
        border-radius: 8px;
        border: 1px solid var(--color-border);
    }

    .toa-thuoc-drug-number {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-primary);
        color: white;
        border-radius: 50%;
        font-weight: 600;
        font-size: 14px;
    }

    .toa-thuoc-drug-content {
        flex: 1;
        min-width: 0;
    }

    .toa-thuoc-drug-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-text-primary);
        margin-bottom: var(--space-2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .toa-thuoc-drug-name i {
        font-size: 18px;
        color: var(--color-primary);
    }

    .toa-thuoc-drug-details {
        display: grid;
        gap: var(--space-2);
    }

    .toa-thuoc-drug-field {
        display: flex;
        gap: var(--space-2);
        font-size: 14px;
        line-height: 1.5;
    }

    .toa-thuoc-drug-field label {
        font-weight: 600;
        color: var(--color-text-secondary);
        min-width: 100px;
        flex-shrink: 0;
    }

    .toa-thuoc-drug-field span {
        color: var(--color-text-primary);
    }

    @@media (max-width: 640px) {
        .toa-thuoc-header {
            flex-direction: column;
        }
        
        .toa-thuoc-count {
            align-self: flex-start;
        }

        .toa-thuoc-drug-field {
            flex-direction: column;
            gap: 4px;
        }

        .toa-thuoc-drug-field label {
            min-width: auto;
        }
    }
</style>
}
