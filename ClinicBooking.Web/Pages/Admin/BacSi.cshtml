<!-- Search and Filters -->
<div class="card">
    <div class="card-header-flex">
        <div class="card-title">Danh sách bác sĩ</div>
        <button class="btn btn-primary" onclick="showModal('modal-create-doctor')">
            <i class="fa-solid fa-plus"></i> Thêm bác sĩ mới
        </button>
    </div>
    
    <div class="search-bar" style="padding: 0 24px 20px;">
        <div class="search-input">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="form-control" id="search-doctors" placeholder="Tìm theo tên, email, SĐT...">
        </div>
        <select class="form-select" style="width: 200px;" id="filter-specialty">
            <option value="">Tất cả chuyên khoa</option>
            <option value="Nội tổng quát">Nội tổng quát</option>
            <option value="Nhi">Nhi</option>
            <option value="Sản">Sản</option>
            <option value="Tim mạch">Tim mạch</option>
        </select>
        <select class="form-select" style="width: 200px;" id="filter-status">
            <option value="">Tất cả trạng thái</option>
            <option value="DangLam">Đang làm việc</option>
            <option value="NghiPhep">Nghỉ phép</option>
            <option value="NghiViec">Nghỉ việc</option>
        </select>
    </div>
</div>

