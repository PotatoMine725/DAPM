<style>
.section-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.section-sub {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 24px;
}

/* ===== CHART CONTAINERS ===== */
.chart-wrap {
    position: relative;
    padding: 20px 24px 12px;
}

.chart-title {
    font-family: 'Lexend', sans-serif;
    font-size: 13.5px;
    font-weight: 700;
    margin-bottom: 4px;
}

.chart-sub {
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 16px;
}

/* ===== BAR CHART ===== */
.bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 180px;
}

.bc-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
    position: relative;
}

.bc-bar-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: 100%;
    position: relative;
}

.bc-bar {
    border-radius: 5px 5px 0 0;
    width: 100%;
    transition: .7s ease;
    cursor: pointer;
    position: relative;
}

.bc-bar:hover {
    filter: brightness(.92);
}

.bc-val {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-secondary);
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
}

.bc-lbl {
    font-size: 11px;
    color: var(--text-disabled);
    white-space: nowrap;
}

/* ===== DONUT CHART ===== */
.donut-chart {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.donut-center {
    position: absolute;
    text-align: center;
}

.donut-center .dc-val {
    font-family: 'Lexend', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
}

.donut-center .dc-lbl {
    font-size: 11px;
    color: var(--text-secondary);
}

/* ===== LEGEND ITEMS ===== */
.donut-legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
}

.dl-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
}

.dl-dot {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
}

.dl-label {
    flex: 1;
    color: var(--text-secondary);
}

.dl-val {
    font-weight: 700;
    color: var(--text-primary);
}

.dl-pct {
    font-size: 12px;
    color: var(--text-disabled);
}

/* ===== HORIZONTAL BAR ===== */
.hbar {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.hbar-item {
    display: grid;
    align-items: center;
    gap: 10px;
    grid-template-columns: 140px 1fr 50px;
}

.hbar-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-align: right;
}

.hbar-track {
    height: 10px;
    background: var(--subtle);
    border-radius: 5px;
    overflow: hidden;
}

.hbar-fill {
    height: 100%;
    border-radius: 5px;
    transition: .8s ease;
}

.hbar-val {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
}

/* ===== KPI CARDS ===== */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 22px;
}

.kpi-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    box-shadow: var(--shadow-sm);
}

.kpi-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 12px;
}

.kpi-icon {
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
}

.kpi-trend {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 20px;
}

.kpi-trend.up {
    background: var(--success-bg);
    color: var(--success);
}

.kpi-trend.down {
    background: var(--danger-bg);
    color: var(--danger);
}

.kpi-trend.neutral {
    background: var(--neutral-bg);
    color: var(--text-secondary);
}

.kpi-val {
    font-family: 'Lexend', sans-serif;
    font-size: 30px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
}

.kpi-label {
    font-size: 12.5px;
    color: var(--text-secondary);
}

.kpi-compare {
    font-size: 12px;
    color: var(--text-disabled);
    margin-top: 8px;
}

/* ===== DATE RANGE ===== */
.date-range-tabs {
    display: flex;
    gap: 2px;
    background: var(--page-bg);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 3px;
}

.dr-tab {
    padding: 7px 16px;
    border-radius: 4px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-secondary);
    cursor: pointer;
    transition: .18s;
}

.dr-tab.active {
    background: var(--white);
    color: var(--primary);
    box-shadow: var(--shadow-sm);
}

</style>

<script>
function setDateRange(range, element) {
    // Update active tab
    document.querySelectorAll('.dr-tab').forEach(tab => tab.classList.remove('active'));
    element.classList.add('active');
    
    // Reload data based on range
    showToast(`Đang tải dữ liệu cho khoảng thời gian: ${range}`, 'info');
    
    // Simulate data loading
    setTimeout(() => {
        showToast('Dữ liệu đã được cập nhật', 'success');
    }, 1000);
}

// Initialize donut chart
document.addEventListener('DOMContentLoaded', function() {
    const canvas = document.getElementById('department-chart');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        drawDonutChart(ctx, 140, 140);
    }
});

function drawDonutChart(ctx, width, height) {
    const centerX = width / 2;
    const centerY = height / 2;
    const radius = 50;
    const innerRadius = 30;
    
    const data = [
        { value: 27.4, color: '#1a5fa8' },
        { value: 23.9, color: '#2e7d32' },
        { value: 33.1, color: '#e65100' },
        { value: 15.6, color: '#7c3aed' }
    ];
    
    let currentAngle = -Math.PI / 2;
    
    data.forEach(segment => {
        const sliceAngle = (segment.value / 100) * 2 * Math.PI;
        
        // Draw outer arc
        ctx.beginPath();
        ctx.arc(centerX, centerY, radius, currentAngle, currentAngle + sliceAngle);
        ctx.arc(centerX, centerY, innerRadius, currentAngle + sliceAngle, currentAngle, true);
        ctx.closePath();
        ctx.fillStyle = segment.color;
        ctx.fill();
        
        currentAngle += sliceAngle;
    });
}
</script>
