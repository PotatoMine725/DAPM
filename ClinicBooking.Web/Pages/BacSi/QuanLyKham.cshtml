@page
@model ClinicBooking.Web.Pages.BacSi.QuanLyKhamModel
@{
    ViewData["Title"] = "Quản lý khám";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý khám</h1>
        <div class="page-subtitle" style="margin-top:var(--space-1); color:var(--color-text-secondary); font-size:13px;">
            Tạo hồ sơ khám, cập nhật chẩn đoán và kê toa theo hồ sơ.
        </div>
    </div>
</div>

<div class="card" style="margin-bottom:var(--space-4); padding:var(--space-4);">
    <form method="get" class="filter-bar" style="align-items:end;">
        <div style="width:220px;">
            <label class="form-label">ID hồ sơ khám</label>
            <input class="form-input" type="number" name="idHoSoKham" value="@Model.IdHoSoKham" min="1" placeholder="Nhập ID hồ sơ" />
        </div>
        <button class="btn btn-secondary" type="submit">
            <i class="ph ph-magnifying-glass"></i> Xem hồ sơ
        </button>
        <a class="btn btn-secondary" href="/BacSi/HangCho">
            <i class="ph ph-users-three"></i> Hàng chờ
        </a>
    </form>
    @if (Model.IdLichHenMoi.HasValue && Model.HoSoHienTai is null)
    {
        <div style="margin-top:var(--space-3); padding:var(--space-3) var(--space-4); background:var(--color-active-bg); border:1px solid var(--color-active-text); border-radius:8px; color:var(--color-active-text); font-size:14px;">
            <i class="ph ph-info"></i> Bệnh nhân từ hàng chờ với lịch hẹn ID <strong>@Model.IdLichHenMoi</strong>.
        </div>
    }
</div>

<div class="module3-two-col">
    <div class="card" style="padding:var(--space-4);">
        <h2 class="card-title qk-section-header qk-section--create" style="margin-bottom:var(--space-3);"><i class="ph ph-file-plus"></i> Tạo hồ sơ khám</h2>
        <form method="post" asp-page-handler="TaoHoSo" class="module3-form">
            <div><label class="form-label">ID lịch hẹn</label><input class="form-input" asp-for="HoSo.IdLichHen" type="number" min="1" required /></div>
            <div><label class="form-label">Chẩn đoán</label><textarea class="form-input" asp-for="HoSo.ChanDoan" rows="3" maxlength="1000"></textarea></div>
            <div><label class="form-label">Kết quả khám</label><textarea class="form-input" asp-for="HoSo.KetQuaKham" rows="3" maxlength="1000"></textarea></div>
            <div><label class="form-label">Ghi chú</label><textarea class="form-input" asp-for="HoSo.GhiChu" rows="2" maxlength="1000"></textarea></div>
            <button class="btn btn-primary" type="submit"><i class="ph ph-floppy-disk"></i> Tạo hồ sơ</button>
        </form>
    </div>

    <div class="card" style="padding:var(--space-4);">
        <h2 class="card-title qk-section-header qk-section--view" style="margin-bottom:var(--space-3);"><i class="ph ph-clipboard-text"></i> Hồ sơ hiện tại</h2>
        @if (Model.HoSoHienTai is null)
        {
            <div class="empty-state" style="padding:var(--space-6);"><div class="empty-state-icon"><i class="ph ph-file-magnifying-glass"></i></div><p>Nhập ID hồ sơ để xem và cập nhật.</p></div>
        }
        else
        {
            <div class="module3-summary">
                <div><span>Mã lịch hẹn</span><strong>@Model.HoSoHienTai.MaLichHen</strong></div>
                <div><span>Ngày khám</span><strong>@Model.HoSoHienTai.NgayKham.ToString("dd/MM/yyyy HH:mm")</strong></div>
                <div><span>Bác sĩ</span><strong>@Model.HoSoHienTai.HoTenBacSi</strong></div>
            </div>

            <div style="margin-top:var(--space-3);">
                <h3 class="card-title" style="margin-bottom:var(--space-2);">Lịch sử khám gần nhất của bệnh nhân</h3>
                @if (!Model.LichSuKhamGanDay.Any())
                {
                    <div class="text-muted">Chưa có lịch sử khám.</div>
                }
                else
                {
                    <div class="module3-history">
                        @foreach (var hs in Model.LichSuKhamGanDay)
                        {
                            <div class="module3-history-item">
                                <div style="display:flex; justify-content:space-between; gap:var(--space-2);">
                                    <strong>@hs.NgayKham.ToString("dd/MM/yyyy HH:mm")</strong>
                                    <span class="text-muted">@hs.HoTenBacSi</span>
                                </div>
                                <div class="text-muted" style="font-size:13px; margin-top:4px;">@(string.IsNullOrWhiteSpace(hs.ChanDoan) ? "Chưa có chẩn đoán." : hs.ChanDoan)</div>
                                <div style="margin-top:4px;"><a href="/BacSi/QuanLyKham?idHoSoKham=@hs.IdHoSoKham">Mở hồ sơ #@hs.IdHoSoKham</a></div>
                            </div>
                        }
                    </div>
                }
            </div>

            <form method="post" asp-page-handler="CapNhatHoSo" class="module3-form" style="margin-top:var(--space-4);">
                <input type="hidden" name="HoSo.IdHoSoKham" value="@Model.HoSoHienTai.IdHoSoKham" />
                <div><label class="form-label">Chẩn đoán</label><textarea class="form-input" name="HoSo.ChanDoan" rows="3">@Model.HoSoHienTai.ChanDoan</textarea></div>
                <div><label class="form-label">Kết quả khám</label><textarea class="form-input" name="HoSo.KetQuaKham" rows="3">@Model.HoSoHienTai.KetQuaKham</textarea></div>
                <div><label class="form-label">Ghi chú</label><textarea class="form-input" name="HoSo.GhiChu" rows="2">@Model.HoSoHienTai.GhiChu</textarea></div>
                <button class="btn btn-primary" type="submit"><i class="ph ph-pencil-simple"></i> Cập nhật hồ sơ</button>
            </form>
        }
    </div>
</div>

@if (Model.HoSoHienTai is not null)
{
    <div class="card" style="margin-top:var(--space-4); padding:var(--space-4);">
        <h2 class="card-title qk-section-header qk-section--toa" style="margin-bottom:var(--space-3);"><i class="ph ph-pill"></i> Kê toa thuốc</h2>
        @if (Model.ToaHienTai.Any())
        {
            <table class="data-table" style="margin-bottom:var(--space-4);">
                <thead><tr><th>Thuốc</th><th>Liều lượng</th><th>Cách dùng</th><th>Số ngày</th><th>Ghi chú</th></tr></thead>
                <tbody>
                @foreach (var toa in Model.ToaHienTai)
                {
                    <tr><td>@toa.TenThuoc</td><td>@toa.LieuLuong</td><td>@toa.CachDung</td><td>@toa.SoNgayDung</td><td>@toa.GhiChu</td></tr>
                }
                </tbody>
            </table>
        }

        <form method="post" asp-page-handler="KeToa">
            <input type="hidden" name="ToaThuoc.IdHoSoKham" value="@Model.HoSoHienTai.IdHoSoKham" />
            <input type="hidden" name="ToaThuoc.CapNhatToaDangCo" value="@(Model.ToaHienTai.Any().ToString().ToLowerInvariant())" />
            <div class="module3-prescription">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="module3-prescription-row">
                        <select class="form-input" name="ToaThuoc.DanhSachThuoc[@i].IdThuoc">
                            <option value="0">Chọn thuốc</option>
                            @foreach (var thuoc in Model.DanhSachThuoc)
                            {
                                <option value="@thuoc.IdThuoc">@thuoc.TenThuoc (@thuoc.DonVi)</option>
                            }
                        </select>
                        <input class="form-input" name="ToaThuoc.DanhSachThuoc[@i].LieuLuong" placeholder="Liều lượng" />
                        <input class="form-input" name="ToaThuoc.DanhSachThuoc[@i].CachDung" placeholder="Cách dùng" />
                        <input class="form-input" name="ToaThuoc.DanhSachThuoc[@i].SoNgayDung" type="number" min="1" placeholder="Số ngày" />
                        <input class="form-input" name="ToaThuoc.DanhSachThuoc[@i].GhiChu" placeholder="Ghi chú" />
                    </div>
                }
            </div>
            <div style="display:flex; gap:var(--space-2); margin-top:var(--space-3); align-items:center;">
                <button class="btn btn-primary" type="submit"><i class="ph ph-pill"></i> @(Model.ToaHienTai.Any() ? "Cập nhật toa" : "Kê toa")</button>
            </div>
        </form>
    </div>
}

@section Scripts {
<style>
.module3-two-col { display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:var(--space-4); }
.module3-form { display:grid; gap:var(--space-3); }
.module3-summary { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:var(--space-3); }
.module3-summary div { border:1px solid var(--color-border-light); padding:var(--space-3); border-radius:8px; }
.module3-summary span { display:block; color:var(--color-text-secondary); font-size:12px; margin-bottom:4px; }
.module3-prescription { display:grid; gap:var(--space-2); }
.module3-prescription-row { display:grid; grid-template-columns:2fr repeat(4, minmax(0, 1fr)); gap:var(--space-2); }
.module3-history { display:grid; gap:var(--space-2); }
.module3-history-item { border:1px solid var(--color-border-light); border-radius:8px; padding:var(--space-2) var(--space-3); }
@@media (max-width: 1000px) {
    .module3-two-col { grid-template-columns:1fr; }
    .module3-summary { grid-template-columns:1fr; }
    .module3-prescription-row { grid-template-columns:1fr; }
}
.qk-section-header { display:flex; align-items:center; gap:8px; padding:10px 14px; border-radius:10px; font-size:15px; }
.qk-section--create { background:#e8f0fb; color:#1a5fa8; border-left:4px solid #1a5fa8; }
.qk-section--view   { background:#f0fdf4; color:#166534; border-left:4px solid #16a34a; }
.qk-section--toa    { background:#fff7ed; color:#92400e; border-left:4px solid #f97316; }
</style>
}
