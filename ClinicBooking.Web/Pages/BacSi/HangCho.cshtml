@page "{idCaLamViec:int?}"
@model ClinicBooking.Web.Pages.BacSi.HangChoModel
@using ClinicBooking.Domain.Enums
@{
    ViewData["Title"] = "Hàng chờ của tôi";
}

<div class="page-header">
    <h1 class="page-title">Hàng chờ của tôi</h1>
    @if (Model.IdCaLamViec.HasValue && Model.SoChoKham > 0)
    {
        <form method="post" asp-page-handler="GoiKeTiep">
            <input type="hidden" name="idCaLamViec" value="@Model.IdCaLamViec" />
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M12 3a4 4 0 0 0-4 4v4c0 .8-.3 1.6-.8 2.2L6 15h12l-1.2-1.8c-.5-.6-.8-1.4-.8-2.2V7a4 4 0 0 0-4-4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M10 18a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Gọi bệnh nhân tiếp theo
            </button>
        </form>
    }
</div>

<!-- Chọn ca làm việc -->
<div class="card" style="margin-bottom: var(--space-4); padding: var(--space-4) var(--space-5);">
    <form method="get" style="display:flex; gap:var(--space-3); align-items:center;">
        <label class="form-label" style="margin:0; white-space:nowrap;">Mã ca làm việc:</label>
        <input type="number" class="form-input" name="idCaLamViec"
               value="@Model.IdCaLamViec" placeholder="Nhập ID ca..." style="width:160px;" />
        <button type="submit" class="btn btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Xem hàng chờ
        </button>
    </form>
</div>

@if (Model.IdCaLamViec.HasValue)
{
    <!-- Thống kê nhanh -->
    <div class="stats-grid" style="grid-template-columns: repeat(3,1fr); margin-bottom: var(--space-4);">
        <div class="stat-card">
            <div class="stat-icon" style="background:var(--color-neutral-bg); color:var(--color-text-secondary);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="vertical-align:-2px; margin-right:4px;"><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
                <div class="stat-value">@Model.SoChoKham</div>
                <div class="stat-label">Đang chờ khám</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:var(--color-active-bg); color:var(--color-active-text);">
                <i class="ph ph-stethoscope"></i>
            </div>
            <div>
                <div class="stat-value">@Model.SoDangKham</div>
                <div class="stat-label">Đang khám</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:var(--color-success-bg); color:var(--color-success-text);">
                <i class="ph ph-check-circle"></i>
            </div>
            <div>
                <div class="stat-value">@Model.SoHoanThanh</div>
                <div class="stat-label">Hoàn thành</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title">Ca #@Model.IdCaLamViec — Danh sách bệnh nhân</span>
        </div>

        @if (!Model.HangCho.Any())
        {
            <div class="empty-state" style="padding: var(--space-8);">
                <div class="empty-state-icon"><i class="ph ph-users"></i></div>
                <p>Hàng chờ trống.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:60px;">STT</th>
                        <th>Mã LH</th>
                        <th>Bệnh nhân</th>
                        <th>Check-in lúc</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hc in Model.HangCho)
                    {
                        <tr class="@(hc.TrangThai == TrangThaiHangCho.DangKham ? "row-highlight" : "")">
                            <td>
                                <strong style="font-size:20px; color:var(--color-primary);">@hc.SoThuTu</strong>
                            </td>
                            <td><span class="table-code">@hc.MaLichHen</span></td>
                            <td>
                                <span style="font-weight:500;">@hc.HoTenBenhNhan</span>
                            </td>
                            <td>@hc.NgayCheckIn.ToString("HH:mm")</td>
                            <td>@Html.Raw(BadgeHelper.TrangThaiHangCho(hc.TrangThai))</td>
                            <td class="table-actions">
                                @if (hc.TrangThai == TrangThaiHangCho.DangKham)
                                {
                                    <form method="post" asp-page-handler="HoanThanh" style="display:inline;">
                                        <input type="hidden" name="idHangCho" value="@hc.IdHangCho" />
                                        <input type="hidden" name="idCaLamViec" value="@Model.IdCaLamViec" />
                                        <button class="btn btn-sm btn-primary">
                                            <i class="ph ph-check"></i> Hoàn thành
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state" style="padding: var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-clipboard-text"></i></div>
            <p>Nhập mã ca làm việc để xem danh sách bệnh nhân chờ khám.</p>
        </div>
    </div>
}

@section Scripts {
<style>
    .row-highlight td { background: var(--color-active-bg); }
</style>
}
