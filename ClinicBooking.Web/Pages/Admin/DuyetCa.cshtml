<style>
.shifts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    margin-bottom: 24px;
}

.shift-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    transition: .2s;
}

.shift-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.shift-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
}

.shift-info .shift-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
}

.shift-info .shift-subtitle {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 2px;
}

.shift-time {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding: 12px;
    background: var(--page-bg);
    border-radius: var(--radius-sm);
}

.shift-time i {
    color: var(--primary);
    font-size: 16px;
}

.shift-details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
}

.detail-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
}

.detail-item i {
    width: 16px;
    text-align: center;
    color: var(--text-disabled);
}

.shift-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.btn-success {
    background: var(--success);
    color: white;
}

.btn-success:hover {
    background: #2e6930;
}

.shift-detail-view .detail-section {
    margin-bottom: 24px;
}

.shift-detail-view .detail-section h4 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--subtle);
}

.detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.detail-grid .detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.detail-grid .detail-item label {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
}

.detail-grid .detail-item span {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
}

.timeline {
    position: relative;
    padding-left: 20px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
}

.timeline-item {
    position: relative;
    padding-bottom: 20px;
}

.timeline-dot {
    position: absolute;
    left: -14px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--primary);
    border: 2px solid var(--white);
}

.timeline-content {
    background: var(--page-bg);
    padding: 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
}
</style>

<script>
let currentShiftId = null;

function approveShift(shiftId) {
    if (confirm('Bạn có chắc muốn duyệt ca làm việc này?')) {
        // Approve shift logic here
        showToast('Ca làm việc đã được duyệt!', 'success');
        removeShiftCard(shiftId);
        updatePendingCount();
    }
}

function rejectShift(shiftId) {
    const reason = prompt('Lý do từ chối:');
    if (reason) {
        // Reject shift logic here
        showToast('Ca làm việc đã bị từ chối!', 'warning');
        removeShiftCard(shiftId);
        updatePendingCount();
    }
}

function approveAllPending() {
    if (confirm('Bạn có chắc muốn duyệt tất cả các ca đang chờ?')) {
        // Approve all shifts logic here
        showToast('Tất cả ca đã được duyệt!', 'success');
        document.querySelectorAll('.shift-card').forEach(card => card.remove());
        updatePendingCount();
    }
}

function viewDetails(shiftId) {
    currentShiftId = shiftId;
    // Load shift details
    showModal('modal-shift-details');
}

function approveShiftFromModal() {
    if (currentShiftId) {
        approveShift(currentShiftId);
        hideModal('modal-shift-details');
    }
}

function rejectShiftFromModal() {
    if (currentShiftId) {
        rejectShift(currentShiftId);
        hideModal('modal-shift-details');
    }
}

function removeShiftCard(shiftId) {
    // Find and remove the shift card
    const cards = document.querySelectorAll('.shift-card');
    cards.forEach(card => {
        if (card.innerHTML.includes(`#${shiftId}`)) {
            card.remove();
        }
    });
}

function updatePendingCount() {
    const count = document.querySelectorAll('.shift-card').length;
    document.getElementById('pending-count').textContent = count;
    
    // Update sidebar badge
    const badge = document.querySelector('.nav-item[data-page="duyetca"] .badge');
    if (badge) {
        badge.textContent = count;
        badge.style.display = count > 0 ? '' : 'none';
    }
}

// Filter functionality
document.getElementById('filter-specialty')?.addEventListener('change', filterShifts);
document.getElementById('filter-date')?.addEventListener('change', filterShifts);

function filterShifts() {
    const specialty = document.getElementById('filter-specialty').value;
    const date = document.getElementById('filter-date').value;
    const cards = document.querySelectorAll('.shift-card');
    
    cards.forEach(card => {
        let show = true;
        
        if (specialty && !card.textContent.includes(specialty)) {
            show = false;
        }
        
        if (date && !card.textContent.includes(date)) {
            show = false;
        }
        
        card.style.display = show ? '' : 'none';
    });
}
</script>
