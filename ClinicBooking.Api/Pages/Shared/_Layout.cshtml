<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicBooking Module 2</title>
    <link rel="stylesheet" href="~/css/module2-theme.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="container topbar-inner">
            <div>
                <h1>ClinicBooking</h1>
                <p class="muted">Module 2 - Bac si, lich lam viec va danh muc</p>
            </div>
            <a class="swagger-link" href="/swagger" target="_blank" rel="noopener noreferrer">Mo Swagger</a>
        </div>
    </header>

    <main class="container page-content">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
