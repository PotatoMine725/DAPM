@page "{idCaLamViec:int?}"
@model ClinicBooking.Web.Pages.LeTan.HangChoModel
@using ClinicBooking.Domain.Enums
@{
    ViewData["Title"] = "Hàng chờ khám";
}

<div class="page-header">
    <h1 class="page-title">Hàng chờ khám</h1>
    @if (Model.IdCaLamViec.HasValue)
    {
        <form method="post" asp-page-handler="GoiKeTiep">
            <input type="hidden" name="idCaLamViec" value="@Model.IdCaLamViec" />
            <button type="submit" class="btn btn-primary">
                <i class="ph ph-bell-ringing"></i> Gọi bệnh nhân tiếp theo
            </button>
        </form>
    }
</div>

<!-- Chọn ca làm việc -->
<div class="card" style="margin-bottom: var(--space-4); padding: var(--space-4) var(--space-5);">
    <form method="get" style="display:flex; gap:var(--space-3); align-items:center; flex-wrap:wrap;">
        <label class="form-label" style="margin:0; white-space:nowrap;">
            <i class="ph ph-calendar-check"></i> Ca làm việc:
        </label>
        @if (Model.DanhSachCa.Any())
        {
            <select class="form-select" name="idCaLamViec" style="min-width:340px;"
                    onchange="this.form.submit()">
                <option value="">— Chọn ca —</option>
                @foreach (var ca in Model.DanhSachCa)
                {
                    var label = $"Ca #{ca.IdCaLamViec} | {ca.NgayLamViec:dd/MM} {ca.GioBatDau:HH\\:mm}–{ca.GioKetThuc:HH\\:mm} | {ca.HoTenBacSi}";
                    if (Model.IdCaLamViec == ca.IdCaLamViec)
                    {
                        <option value="@ca.IdCaLamViec" selected>@label</option>
                    }
                    else
                    {
                        <option value="@ca.IdCaLamViec">@label</option>
                    }
                }
            </select>
        }
        else
        {
            <span style="color:var(--color-text-secondary); font-size:14px;">
                Không có ca nào hôm nay và ngày mai.
            </span>
        }
    </form>
</div>

@if (Model.IdCaLamViec.HasValue)
{
    <div class="card">
        <div class="card-header">
            <span class="card-title">
                Ca #@Model.IdCaLamViec
                — <span style="color:var(--color-active-text);">@Model.SoChoKham đang chờ</span>
            </span>
            <span style="font-size:13px; color:var(--color-text-secondary);">
                Đang khám: @Model.SoDangKham | Hoàn thành: @Model.SoHoanThanh
            </span>
        </div>

        @if (!Model.HangCho.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="ph ph-users"></i></div>
                <p>Hàng chờ trống.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:60px;">STT</th>
                        <th>Mã LH</th>
                        <th>Bệnh nhân</th>
                        <th>Check-in lúc</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hc in Model.HangCho)
                    {
                        <tr>
                            <td><strong style="font-size:18px;">@hc.SoThuTu</strong></td>
                            <td><span class="table-code">@hc.MaLichHen</span></td>
                            <td>@hc.HoTenBenhNhan</td>
                            <td>@hc.NgayCheckIn.ToString("HH:mm")</td>
                            <td>@Html.Raw(BadgeHelper.TrangThaiHangCho(hc.TrangThai))</td>
                            <td class="table-actions">
                                @if (hc.TrangThai == TrangThaiHangCho.DangKham)
                                {
                                    <form method="post" asp-page-handler="HoanThanh" style="display:inline;">
                                        <input type="hidden" name="idHangCho" value="@hc.IdHangCho" />
                                        <input type="hidden" name="idCaLamViec" value="@Model.IdCaLamViec" />
                                        <button class="btn btn-sm btn-primary">Hoàn thành</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state" style="padding: var(--space-8);">
            <div class="empty-state-icon"><i class="ph ph-users-three"></i></div>
            <p>Nhập mã ca làm việc để xem hàng chờ.</p>
        </div>
    </div>
}
