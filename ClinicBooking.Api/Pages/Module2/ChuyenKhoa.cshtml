@page "/module2/chuyen-khoa"
@model ClinicBooking.Api.Pages.Module2.ChuyenKhoaModel
@{
    ViewData["Title"] = "Quan ly Chuyen Khoa";
}

<section class="grid">
    <article class="card">
        <h2>Tao Chuyen Khoa</h2>
        <p class="small">Giao dien desktop theo phong cach y te, phuc vu thao tac nhanh cho admin.</p>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="status-banner status-success">@Model.SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="status-banner status-error">@Model.ErrorMessage</div>
        }

        <form method="post" asp-page-handler="Create">
            <div class="form-field">
                <label asp-for="TaoMoi.TenChuyenKhoa"></label>
                <input asp-for="TaoMoi.TenChuyenKhoa" />
                <span asp-validation-for="TaoMoi.TenChuyenKhoa" class="small"></span>
            </div>

            <div class="form-field">
                <label asp-for="TaoMoi.MoTa"></label>
                <textarea asp-for="TaoMoi.MoTa"></textarea>
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="TaoMoi.ThoiGianSlotMacDinh"></label>
                    <input asp-for="TaoMoi.ThoiGianSlotMacDinh" type="number" min="1" max="1440" />
                </div>
                <div class="form-field">
                    <label asp-for="TaoMoi.HienThi">Hien thi</label>
                    <select asp-for="TaoMoi.HienThi">
                        <option value="true">Co</option>
                        <option value="false">Khong</option>
                    </select>
                </div>
                <div class="form-field">
                    <label asp-for="TaoMoi.GioMoDatLich"></label>
                    <input asp-for="TaoMoi.GioMoDatLich" type="time" step="1" />
                </div>
                <div class="form-field">
                    <label asp-for="TaoMoi.GioDongDatLich"></label>
                    <input asp-for="TaoMoi.GioDongDatLich" type="time" step="1" />
                </div>
            </div>

            <div class="actions">
                <button class="btn btn-primary" type="submit">Tao moi</button>
            </div>
        </form>
    </article>

    <article class="card">
        <h2>Danh Sach Chuyen Khoa</h2>
        <form method="get" class="form-grid" style="margin-bottom: 14px;">
            <div class="form-field">
                <label for="tuKhoa">Tu khoa</label>
                <input id="tuKhoa" name="TuKhoa" value="@Model.TuKhoa" placeholder="Tim theo ten chuyen khoa" />
            </div>
            <div class="form-field">
                <label for="hienThi">Trang thai hien thi</label>
                <select id="hienThi" name="HienThi">
                    <option value="">Tat ca</option>
                    @if (Model.HienThi == true)
                    {
                        <option value="true" selected>Dang hien</option>
                    }
                    else
                    {
                        <option value="true">Dang hien</option>
                    }
                    @if (Model.HienThi == false)
                    {
                        <option value="false" selected>Dang an</option>
                    }
                    else
                    {
                        <option value="false">Dang an</option>
                    }
                </select>
            </div>
            <div class="form-field">
                <label for="soTrang">So trang</label>
                <input id="soTrang" name="SoTrang" type="number" value="@Model.SoTrang" min="1" />
            </div>
            <div class="form-field">
                <label for="kichThuocTrang">Kich thuoc trang</label>
                <input id="kichThuocTrang" name="KichThuocTrang" type="number" value="@Model.KichThuocTrang" min="1" max="100" />
            </div>
            <div class="actions">
                <button class="btn btn-secondary" type="submit">Loc danh sach</button>
            </div>
        </form>

        <div class="table-wrap">
            <table>
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Ten chuyen khoa</th>
                    <th>Slot (phut)</th>
                    <th>Khung gio dat</th>
                    <th>Trang thai</th>
                    <th>Thao tac</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.DanhSach.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="small">Khong co du lieu phu hop bo loc.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.DanhSach)
                    {
                        <tr>
                            <td>@item.IdChuyenKhoa</td>
                            <td>
                                <strong>@item.TenChuyenKhoa</strong>
                                <div class="small">@item.MoTa</div>
                            </td>
                            <td>@item.ThoiGianSlotMacDinh</td>
                            <td>@item.GioMoDatLich - @item.GioDongDatLich</td>
                            <td>
                                <span class="badge @(item.HienThi ? "badge-success" : "badge-neutral")">
                                    @(item.HienThi ? "Dang hien" : "Dang an")
                                </span>
                            </td>
                            <td>
                                <div class="row-actions">
                                    <details>
                                        <summary>Sua</summary>
                                        <form method="post" asp-page-handler="Update" style="margin-top:10px; min-width: 380px;">
                                            <input type="hidden" name="IdChuyenKhoa" value="@item.IdChuyenKhoa" />
                                            <input type="hidden" name="SoTrang" value="@Model.SoTrang" />
                                            <input type="hidden" name="KichThuocTrang" value="@Model.KichThuocTrang" />
                                            <input type="hidden" name="HienThi" value="@Model.HienThi" />
                                            <input type="hidden" name="TuKhoa" value="@Model.TuKhoa" />

                                            <div class="form-field">
                                                <label>Ten chuyen khoa</label>
                                                <input name="TenChuyenKhoa" value="@item.TenChuyenKhoa" required maxlength="450" />
                                            </div>
                                            <div class="form-field">
                                                <label>Mo ta</label>
                                                <textarea name="MoTa">@item.MoTa</textarea>
                                            </div>
                                            <div class="form-grid">
                                                <div class="form-field">
                                                    <label>Thoi gian slot mac dinh</label>
                                                    <input type="number" name="ThoiGianSlotMacDinh" value="@item.ThoiGianSlotMacDinh" min="1" max="1440" required />
                                                </div>
                                                <div class="form-field">
                                                    <label>Hien thi</label>
                                                    <select name="HienThi">
                                                        @if (item.HienThi)
                                                        {
                                                            <option value="true" selected>Co</option>
                                                            <option value="false">Khong</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="true">Co</option>
                                                            <option value="false" selected>Khong</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="form-field">
                                                    <label>Gio mo dat lich</label>
                                                    <input type="time" step="1" name="GioMoDatLich" value="@item.GioMoDatLich" />
                                                </div>
                                                <div class="form-field">
                                                    <label>Gio dong dat lich</label>
                                                    <input type="time" step="1" name="GioDongDatLich" value="@item.GioDongDatLich" />
                                                </div>
                                            </div>
                                            <button class="btn btn-primary" type="submit">Luu cap nhat</button>
                                        </form>
                                    </details>
                                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Ban co chac chan muon xoa chuyen khoa nay?');">
                                        <input type="hidden" name="idChuyenKhoa" value="@item.IdChuyenKhoa" />
                                        <input type="hidden" name="SoTrang" value="@Model.SoTrang" />
                                        <input type="hidden" name="KichThuocTrang" value="@Model.KichThuocTrang" />
                                        <input type="hidden" name="HienThi" value="@Model.HienThi" />
                                        <input type="hidden" name="TuKhoa" value="@Model.TuKhoa" />
                                        <button class="btn btn-danger" type="submit">Xoa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </article>
</section>
